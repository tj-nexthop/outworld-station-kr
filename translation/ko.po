# ---------------------------------------------------------- DT_ContractText
msgctxt "DT_ContractText@e0@4f"
msgid "<Bold>Mission Complete</>, Station Commander."
msgstr "<Bold>임무 완료</>, 스테이션 사령관님."

msgctxt "DT_ContractText@e0@b0"
msgid "<Bold>Congratulations</> Commander, Mission accomplished."
msgstr "<Bold>축하합니다</> 사령관님, 임무 달성."

msgctxt "DT_ContractText@e0@11d"
msgid "<Bold>Primary objective completed</>. well done, Station Commander."
msgstr "<Bold>주요 목표 완료</>. 잘하셨습니다, 스테이션 사령관님."

msgctxt "DT_ContractText@e0@1a6"
msgid "New <bold>technologies, modules, items</> and <bold>parts</> are now available for you to unlock..."
msgstr "이제 새로운 <bold>기술, 모듈, 아이템</> 및 <bold>부품</>을 잠금 해제할 수 있습니다..."

msgctxt "DT_ContractText@e0@24f"
msgid "To continue, select a new objective from the <Bold>Objectives Panel</>..."
msgstr "계속하려면 <Bold>목표 패널</>에서 새 목표를 선택하세요..."

msgctxt "DT_ContractText@e0@2cc"
msgid "When you're ready, open the <Bold>Objectives Panel</> to continue expanding your station..."
msgstr "준비되시면 <Bold>목표 패널</>을 열어 스테이션 확장을 계속하세요..."

msgctxt "DT_ContractText@e0@35b"
msgid "More objectives are available from the <Bold>Objectives Panel</>..."
msgstr "<Bold>목표 패널</>에서 더 많은 목표를 사용할 수 있습니다..."

msgctxt "DT_ContractText@e0@3d2"
msgid "Choose another objective from the <Bold>Objectives Panel</>..."
msgstr "<Bold>목표 패널</>에서 다른 목표를 선택하세요..."

msgctxt "DT_ContractText@e0@444"
msgid "The <Bold>Objectives Panel</> contains new objectives for you..."
msgstr "<Bold>목표 패널</>에 새로운 목표가 준비되어 있습니다..."

msgctxt "DT_ContractText@e0@4de"
msgid "Welcome to the <Bold>TAU</> system, <Bold>Station Commander</>..."
msgstr "<Bold>TAU</> 성계에 오신 것을 환영합니다, <Bold>스테이션 사령관님</>..."

msgctxt "DT_ContractText@e0@553"
msgid "Located on the fringes of the known galaxy, <Bold>Nova Corp</> has singled out this system for <Bold>exploitation and expansion</>.\r\n\r\nAs one of our newest <Bold>Station Commanders</>, we expect <Bold>big things</> from you - but <Bold>don't worry</>, I'll be here to guide you along the way..."
msgstr "알려진 은하 변두리에 위치한 이 성계를 <Bold>노바 코프</>가 <Bold>개발 및 확장</> 대상으로 선정했습니다.\n\n저희의 새로운 <Bold>스테이션 사령관</> 중 한 분으로서 <Bold>큰 성과</>를 기대합니다 — 그러나 <Bold>걱정 마세요</>, 제가 길을 안내해 드리겠습니다..."

msgctxt "DT_ContractText@e0@6ad"
msgid "Open the <Bold>Objectives Panel</> to select an objective and start developing your station."
msgstr "<Bold>목표 패널</>을 열어 목표를 선택하고 스테이션 개발을 시작하세요."

msgctxt "DT_ContractText@e0@74f"
msgid "To continue developing your station,"
msgstr "스테이션 개발을 계속하려면,"

msgctxt "DT_ContractText@e0@7a7"
msgid "To reach the next Station Level,"
msgstr "다음 스테이션 레벨에 도달하려면,"

msgctxt "DT_ContractText@e0@7fb"
msgid "To expand your station further,"
msgstr "스테이션을 더 확장하려면,"

msgctxt "DT_ContractText@e0@84e"
msgid "To fulfil your next objective,"
msgstr "다음 목표를 달성하려면,"

msgctxt "DT_ContractText@e0@8b2"
msgid "Let us know when you have all of the required items."
msgstr "필요한 아이템을 모두 갖추시면 알려주세요."

msgctxt "DT_ContractText@e0@91a"
msgid "We'll be in contact when you've fulfilled all of the objectives."
msgstr "모든 목표를 달성하시면 연락드리겠습니다."

msgctxt "DT_ContractText@e0@98e"
msgid "Better get to work, Station Commander."
msgstr "작업에 착수하시는 게 좋겠습니다, 스테이션 사령관님."

msgctxt "DT_ContractText@e0@9e8"
msgid "No time to waste, Commander."
msgstr "낭비할 시간이 없습니다, 사령관님."

msgctxt "DT_ContractText@e0@a4a"
msgid "we'll need you to construct the following ships:\r\n\r\n<Ships>..."
msgstr "다음 함선들을 건조해 주셔야 합니다:\n\n<Ships>..."

msgctxt "DT_ContractText@e0@abc"
msgid "the following starships need to be constructed:\r\n\r\n<Ships>..."
msgstr "다음 우주선들을 건조해야 합니다:\n\n<Ships>..."

msgctxt "DT_ContractText@e0@b2d"
msgid "please make sure you construct these ships:\r\n\r\n<Ships>..."
msgstr "다음 함선들을 반드시 건조해 주세요:\n\n<Ships>..."

msgctxt "DT_ContractText@e0@b9a"
msgid "make sure you have the following starships:\r\n\r\n<Ships>..."
msgstr "다음 우주선들을 갖추셔야 합니다:\n\n<Ships>..."

msgctxt "DT_ContractText@e0@c07"
msgid "please build these ships:\r\n\r\n<Ships>..."
msgstr "다음 함선들을 건조해 주세요:\n\n<Ships>..."

msgctxt "DT_ContractText@e0@c74"
msgid "we'll need you to manufacture the following items:\r\n\r\n<Items>..."
msgstr "다음 아이템들을 제조해 주셔야 합니다:\n\n<Items>..."

msgctxt "DT_ContractText@e0@ce8"
msgid "the following items need to be constructed:\r\n\r\n<Items>..."
msgstr "다음 아이템들을 제작해야 합니다:\n\n<Items>..."

msgctxt "DT_ContractText@e0@d55"
msgid "please fulfil these items:\r\n\r\n<Items>..."
msgstr "다음 아이템들을 채워 주세요:\n\n<Items>..."

msgctxt "DT_ContractText@e0@db1"
msgid "we need these items to be in your HUB:\r\n\r\n<Items>..."
msgstr "이 아이템들이 허브에 있어야 합니다:\n\n<Items>..."

msgctxt "DT_ContractText@e0@f1b"
msgid "You've done some truly amazing work in this sector, Commander.\r\n\r\n<Bold>Station Command</> has taken notice, and have decided to <Bold>promote</> you to the rank of <Bold>Captain</>!\r\n\r\nYou should feel extremely proud of yourself..."
msgstr "이 구역에서 정말 놀라운 일을 해내셨습니다, 사령관님.\n\n<Bold>스테이션 본부</>가 이를 주목했고, <Bold>대위</> 계급으로 <Bold>승진</>시키기로 결정했습니다!\n\n자부심을 느끼셔도 좋습니다..."

msgctxt "DT_ContractText@e0@1049"
msgid "You've completed the <Bold>initial phase of development</> in this system.\r\n\r\nPlease continue to expand your station and we'll be in touch very soon with <Bold>new technologies</> and <Bold>further orders</>..."
msgstr "이 성계에서 <Bold>개발 초기 단계</>를 완료하셨습니다.\n\n계속해서 스테이션을 확장하시면 곧 <Bold>새 기술</>과 <Bold>추가 명령</>으로 연락드리겠습니다..."

msgctxt "DT_ContractText@e0@1161"
msgid "<Bold>My compliments</>, Station Commander."
msgstr "<Bold>축하 드립니다</>, 스테이션 사령관님."

msgctxt "DT_ContractText@e0@11c0"
msgid "<Bold>Congratulations</> Commander."
msgstr "<Bold>축하합니다</> 사령관님."

msgctxt "DT_ContractText@e0@1217"
msgid "<Bold>Objective Completed</> Commander."
msgstr "<Bold>목표 완료</> 사령관님."

msgctxt "DT_ContractText@e0@1272"
msgid "<Bold>Objective completed</>. well done, Station Commander."
msgstr "<Bold>목표 완료</>. 잘하셨습니다, 스테이션 사령관님."

msgctxt "DT_ContractText@e0@12e1"
msgid "You've completed an Objective - My Compliments."
msgstr "목표를 완료하셨습니다 — 축하 드립니다."

msgctxt "DT_ContractText@e0@1356"
msgid "<Bold>Drone Control Initiated...</>\r\n\r\nWelcome to <Bold>Stargate Control Alpha</>, Station Commander..."
msgstr "<Bold>드론 제어 시작...</>\n\n<Bold>스타게이트 제어 알파</>에 오신 것을 환영합니다, 스테이션 사령관님..."

msgctxt "DT_ContractText@e0@13f1"
msgid "<Enemy>The Void</> is now only light-minutes away from Terra Prime and we're running out of time..."
msgstr "<Enemy>공허</>가 이제 테라 프라임에서 광분 거리밖에 안 떨어져 있고 시간이 부족합니다..."

msgctxt "DT_ContractText@e0@1488"
msgid "We need to get that <Bold>Jumpgate Buffer</> back online now, so we can re-initiate <Bold>The Gate</> and escape to the <Bold>TAU system</> before this system is destroyed."
msgstr "이 성계가 파괴되기 전에 <Bold>게이트</>를 재가동하고 <Bold>TAU 성계</>로 탈출할 수 있도록 그 <Bold>점프게이트 버퍼</>를 즉시 복구해야 합니다."

msgctxt "DT_ContractText@e0@1586"
msgid "We just need to run a few <Bold>tests</> on your Drone's <Bold>control routines</>...\r\n\r\nFollow the steps and then we can get to work."
msgstr "사령관님의 드론 <Bold>제어 루틴</>에 몇 가지 <Bold>테스트</>만 진행하면 됩니다...\n\n단계를 따라가시면 작업을 시작할 수 있습니다."

msgctxt "DT_ContractText@e0@1640"
msgid "OK, now we need to clear the <Enemy>wreckage</> from around the damaged jumpgate buffer before we can replace it.\r\n\r\nWe recommend using your <Bold>Neutron Lazer</> to accomplish this..."
msgstr "좋습니다, 이제 손상된 점프게이트 버퍼 주변의 <Enemy>잔해</>를 교체 전에 제거해야 합니다.\n\n이를 위해 <Bold>중성자 레이저</>를 사용하실 것을 권장합니다..."

msgctxt "DT_ContractText@e0@172d"
msgid "We can now <Bold>deconstruct</> the damaged buffer to clear space for the new buffer we'll need to produce...\r\n\r\nYou can use the <Bold>Sell mode</> to accomplish this."
msgstr "이제 새 버퍼를 생산할 공간을 확보하기 위해 손상된 버퍼를 <Bold>해체</>할 수 있습니다...\n\n이를 위해 <Bold>판매 모드</>를 사용할 수 있습니다."

msgctxt "DT_ContractText@e0@1808"
msgid "We need to get a new buffer up and running as soon as we can, but all our factories were <Bold>dismantled</> to build <Bold>The Gate</>..."
msgstr "가능한 한 빨리 새 버퍼를 가동해야 하지만, 모든 공장은 <Bold>게이트</>를 건설하기 위해 <Bold>해체</>되었습니다..."

msgctxt "DT_ContractText@e0@18c6"
msgid "We'll need to get a small factory up and running to manufacture the <Bold>Stargate Parts</> we need...\r\n\r\nStart by collecting the items left in your <Bold>HUB</>."
msgstr "필요한 <Bold>스타게이트 부품</>을 제조하려면 작은 공장을 가동해야 합니다...\n\n<Bold>허브</>에 남아 있는 아이템부터 수집하세요."

msgctxt "DT_ContractText@e0@199c"
msgid "We'll need some basic materials before we can start building more complex parts..."
msgstr "더 복잡한 부품을 만들기 전에 몇 가지 기본 재료가 필요합니다..."

msgctxt "DT_ContractText@e0@1a22"
msgid "Construct an <Bold>Atomizer</> to let us turn collected asteroids into raw materials, and a <Bold>Smelter</> to turn these into useable metals."
msgstr "수집한 소행성을 원자재로 변환하기 위해 <Bold>분해기</>를 건설하고, 이를 사용 가능한 금속으로 변환하기 위해 <Bold>제련소</>를 건설하세요."

msgctxt "DT_ContractText@e0@1ae5"
msgid "Now our <Bold>Atomizer</> is up and running we can collect asteroids floating around our station and drop them into the opening to process them."
msgstr "이제 <Bold>분해기</>가 가동되었으니 스테이션 주변에 떠 있는 소행성을 수집하고 투입구에 떨어뜨려 처리할 수 있습니다."

msgctxt "DT_ContractText@e0@1ba9"
msgid "All factories need to have a <Bold>recipe</> selected in order to function.\r\n\r\nChoose the <Bold>Titanium</> recipe now from your <Bold>Smelter's popup menu</>."
msgstr "모든 공장은 작동하려면 <Bold>제작법</>이 선택되어 있어야 합니다.\n\n지금 <Bold>제련소 팝업 메뉴</>에서 <Bold>티타늄</> 제작법을 선택하세요."

msgctxt "DT_ContractText@e0@1c7c"
msgid "Automate the movement of items and materials around your station by <Bold>linking</> modules together - they will intelligently <Bold>send required items</> to modules they are linked to.\r\n\r\nLink your <Bold>Atomizer</> to your <Bold>Smelter</> and your <Bold>Smelter</> to your <Bold>HUB</> to start sending items now."
msgstr "모듈을 <Bold>연결</>하여 스테이션 주변의 아이템과 재료 이동을 자동화하세요 — 모듈이 자신과 연결된 모듈로 <Bold>필요한 아이템을</> 지능적으로 <Bold>전송</>합니다.\n\n지금 <Bold>분해기</>를 <Bold>제련소</>에, <Bold>제련소</>를 <Bold>허브</>에 연결하여 아이템 전송을 시작하세요."

msgctxt "DT_ContractText@e0@1dee"
msgid "If you have made a mistake linking modules together you can <Bold>unlink</> them by repeating the same link action.\r\n\r\nWe recommend unlinking your <Bold>Smelter</> from your <Bold>HUB</> now."
msgstr "모듈 연결에 실수가 있었다면 동일한 연결 동작을 반복하여 <Bold>연결을 해제</>할 수 있습니다.\n\n지금 <Bold>제련소</>를 <Bold>허브</>에서 연결 해제하시는 것을 권장합니다."

msgctxt "DT_ContractText@e0@1ee1"
msgid "We're going to need some <Bold>additional modules</> to create our mini factory.\r\n\r\nPlease build the required modules so we can continue."
msgstr "미니 공장을 만들려면 <Bold>추가 모듈</>이 필요합니다.\n\n계속 진행할 수 있도록 필요한 모듈을 건설해 주세요."

msgctxt "DT_ContractText@e0@1f9e"
msgid "Now <Bold>link</> all of your new modules together as directed to form <Bold>supply chains</>."
msgstr "이제 안내에 따라 새 모듈들을 모두 <Bold>연결</>하여 <Bold>공급망</>을 형성하세요."

msgctxt "DT_ContractText@e0@2030"
msgid "Our <Bold>power generation</> is getting dangerously low...\r\n\r\nBuild a <Bold>Solar Panel</> and <Bold>align</> it to the sun's direction to increase power levels."
msgstr "<Bold>전력 생산</>이 위험할 정도로 낮아지고 있습니다...\n\n<Bold>태양광 패널</>을 건설하고 태양 방향으로 <Bold>정렬</>하여 전력 수준을 높이세요."

msgctxt "DT_ContractText@e0@2106"
msgid "Before we continue, please check that these <Bold>advanced functions</> are working correctly as they will come in very useful as your station expands further."
msgstr "계속하기 전에 이 <Bold>고급 기능</>이 올바르게 작동하는지 확인해 주세요. 스테이션이 확장됨에 따라 매우 유용해질 것입니다."

msgctxt "DT_ContractText@e0@21d9"
msgid "All modules have <Bold>advanced settings</> which give you more control over what they will process and store - please test these functions now."
msgstr "모든 모듈에는 처리하고 저장할 항목을 더 잘 제어할 수 있는 <Bold>고급 설정</>이 있습니다 — 지금 이 기능을 테스트해 주세요."

msgctxt "DT_ContractText@e0@229d"
msgid "Completing <Bold>Objectives</> allows us to unlock <Bold>new technologies, items, modules and ships</>.\r\n\r\nSelect the <Bold>Complete The Gate</> objective now from the <Bold>Objectives Panel</>."
msgstr "<Bold>목표</>를 완료하면 <Bold>새로운 기술, 아이템, 모듈 및 함선</>을 잠금 해제할 수 있습니다.\n\n지금 <Bold>목표 패널</>에서 <Bold>게이트 완성</> 목표를 선택하세요."

msgctxt "DT_ContractText@e0@2393"
msgid "To rebuild the damaged buffer unit we'll need to construct complex <Bold>Stargate Parts</>, using the materials our smelters have processed.\r\n\r\nWe can use our Drone's <Bold>Synthesizer</> function to produce these parts. This is accessed from the <Bold>Synthesizer Tab</> on your Drone's <Bold>inventory</> popup menu..."
msgstr "손상된 버퍼 유닛을 재건하려면 제련소가 처리한 재료를 사용해 복잡한 <Bold>스타게이트 부품</>을 제작해야 합니다.\n\n드론의 <Bold>합성기</> 기능으로 이 부품을 생산할 수 있습니다. 드론 <Bold>인벤토리</> 팝업 메뉴의 <Bold>합성기 탭</>에서 접근할 수 있습니다..."

msgctxt "DT_ContractText@e0@2507"
msgid "Now we've fabricated the required <Bold>Stargate Parts</>, we should place these in our <Bold>HUB</> in order to complete the current Objective."
msgstr "이제 필요한 <Bold>스타게이트 부품</>을 제작했으니, 현재 목표를 완료하기 위해 <Bold>허브</>에 배치해야 합니다."

msgctxt "DT_ContractText@e0@25cb"
msgid "If you <Bold>run out of materials</> while synthesizing, don't forget to feed more asteroids into your <Bold>Atomizer</>, and collect more completed materials from your <Bold>HUB</>."
msgstr "합성 중에 <Bold>재료가 바닥나면</> <Bold>분해기</>에 더 많은 소행성을 투입하고 <Bold>허브</>에서 완성된 재료를 더 많이 수집하는 것을 잊지 마세요."

msgctxt "DT_ContractText@e0@2717"
msgid "Local <Bold>star constellations</> fixed and locked...\r\n\r\nConfirmed... We've arrived in the <Bold>TAU system</>, Station Commander..."
msgstr "지역 <Bold>별자리</> 확정 및 고정...\n\n확인 완료... <Bold>TAU 성계</>에 도착했습니다, 스테이션 사령관님..."

msgctxt "DT_ContractText@e0@27d0"
msgid "<Bold>Long-range scans</> reveal that this <Bold>mysterious</> system contains all the raw resources we'll need to develop our <Bold>Intergalactic Arkship</> and escape this galaxy...."
msgstr "<Bold>장거리 스캔</> 결과 이 <Bold>신비로운</> 성계에는 우리의 <Bold>은하 간 방주선</>을 개발하고 이 은하를 탈출하는 데 필요한 모든 원자재가 있는 것으로 나타났습니다...."

msgctxt "DT_ContractText@e0@28bc"
msgid "However, it appears that <Bold>The Void's</> expansion is <Bold>accelerating</>, and we may not have as long here as we hoped before it reaches us again...\r\n\r\n<Bold>So we better get to work, Station Commander!</>"
msgstr "그러나 <Bold>공허</>의 팽창이 <Bold>가속화</>되고 있어, 다시 우리에게 닿기 전까지 우리가 바랐던 만큼의 시간이 없을 수도 있습니다...\n\n<Bold>그러니 작업에 착수하는 게 좋겠습니다, 스테이션 사령관님!</>"

msgctxt "DT_ContractText@e0@29c4"
msgid "Select an <Bold>Objective</> from the <Bold>Objectives Panel</> to start."
msgstr "시작하려면 <Bold>목표 패널</>에서 <Bold>목표</>를 선택하세요."

