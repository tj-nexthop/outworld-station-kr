# ---------------------------------------------------------- DT_Cutscenes
msgctxt "DT_Cutscenes@e0@1c"
msgid "Intro"
msgstr "인트로"

msgctxt "DT_Cutscenes@e0@74"
msgid "Our galaxy is <Red>doomed</>"
msgstr "우리 은하는 <Red>운명을 다했다</>"

msgctxt "DT_Cutscenes@e0@e3"
msgid "Destined to be <Red>consumed</>\r\nby the insatiable appetite"
msgstr "탐욕스러운 식욕에\n<Red>삼켜질 운명</>이다"

msgctxt "DT_Cutscenes@e0@171"
msgid "Of the <Red>monster</>\r\nthat lies at its centre..."
msgstr "그 중심에 도사린\n<Red>괴물</>의 식욕에..."

msgctxt "DT_Cutscenes@e0@1f6"
msgid "<Red_Large>The Void</>"
msgstr "<Red_Large>공허</>"

msgctxt "DT_Cutscenes@e0@25f"
msgid "Our only hope:\r\nTo build a <Yellow>vessel</> capable of leaving this galaxy"
msgstr "우리의 유일한 희망:\n이 은하를 떠날 수 있는 <Yellow>함선</>을 건조하는 것"

msgctxt "DT_Cutscenes@e0@2fd"
msgid "BUT WE'VE RUN OUT OF TIME"
msgstr "하지만 시간이 다 됐다"

msgctxt "DT_Cutscenes@e0@369"
msgid "The Void has reached <Yellow>Terra System</>\r\nand soon our home will be destroyed"
msgstr "공허가 <Yellow>테라 성계</>에 도달했고\n곧 우리 고향은 파괴될 것이다"

msgctxt "DT_Cutscenes@e0@40d"
msgid "So we've mined all our remaining resources"
msgstr "그래서 남은 자원을 모두 채굴했고"

msgctxt "DT_Cutscenes@e0@48a"
msgid "to construct <Yellow>The Gate</>"
msgstr "<Yellow>게이트</>를 건설했다"

msgctxt "DT_Cutscenes@e0@4fd"
msgid "A <Yellow>stargate</> that can take us\r\nto the edge of the Galaxy"
msgstr "은하 끝자락으로 우리를 데려갈\n<Yellow>스타게이트</>"

msgctxt "DT_Cutscenes@e0@590"
msgid "There we can hide - and build"
msgstr "그곳에서 숨고 — 다시 건설할 수 있다"

msgctxt "DT_Cutscenes@e0@600"
msgid "And hopefully escape <Red>The Void</> forever"
msgstr "그리고 <Red>공허</>로부터 영원히 탈출할 수 있기를"

msgctxt "DT_Cutscenes@e0@6d1"
msgid "Arkship... Launching..."
msgstr "방주선... 발진..."

msgctxt "DT_Cutscenes@e0@73b"
msgid "Hyperdrive... Initialised..."
msgstr "하이퍼드라이브... 초기화..."

msgctxt "DT_Cutscenes@e0@7aa"
msgid "Dock is clear..."
msgstr "도크 이상 없음..."

msgctxt "DT_Cutscenes@e0@80d"
msgid "We are away..."
msgstr "출발..."

msgctxt "DT_Cutscenes@e0@86e"
msgid "Entering Void Event Horizon in 3..."
msgstr "공허 사건 지평선 진입까지 3..."

msgctxt "DT_Cutscenes@e0@992"
msgid "Entering Void..."
msgstr "공허 진입..."

msgctxt "DT_Cutscenes@e0@a21"
msgid "Arkship... Launching..."
msgstr "방주선... 발진..."

msgctxt "DT_Cutscenes@e0@a8b"
msgid "Hyperdrive... Initialised..."
msgstr "하이퍼드라이브... 초기화..."

msgctxt "DT_Cutscenes@e0@afa"
msgid "Dock is clear..."
msgstr "도크 이상 없음..."

msgctxt "DT_Cutscenes@e0@b5d"
msgid "We are away..."
msgstr "출발..."

msgctxt "DT_Cutscenes@e0@bbe"
msgid "Destination... Andromeda Galaxy... Locked..."
msgstr "목적지... 안드로메다 은하... 설정 완료..."

msgctxt "DT_Cutscenes@e0@c3d"
msgid "Hyperdrive Engaging..."
msgstr "하이퍼드라이브 작동..."

# ---------------------------------------------------------- DT_DroneEquipment
msgctxt "DT_DroneEquipment@e0@4f"
msgid "Afterburner"
msgstr "애프터버너"

msgctxt "DT_DroneEquipment@e0@93"
msgid "Jet Booster that dramatically increases your drone's speed for a short time"
msgstr "드론 속도를 짧은 시간 동안 크게 증가시키는 제트 부스터"

msgctxt "DT_DroneEquipment@e0@14c"
msgid "Missile Launcher"
msgstr "미사일 발사기"

msgctxt "DT_DroneEquipment@e0@195"
msgid "Launches explosive rockets that can home in on a target"
msgstr "목표를 추적하는 폭발성 로켓을 발사합니다"

msgctxt "DT_DroneEquipment@e0@22f"
msgid "Neutron Lazer"
msgstr "중성자 레이저"

msgctxt "DT_DroneEquipment@e0@275"
msgid "Powerful beam lazer than can destroy enemies and incoming meteors"
msgstr "적과 다가오는 운석을 파괴할 수 있는 강력한 빔 레이저"

msgctxt "DT_DroneEquipment@e0@316"
msgid "Sensors"
msgstr "센서"

msgctxt "DT_DroneEquipment@e0@356"
msgid "Scans the local area for items, resources and threats"
msgstr "주변 지역에서 아이템, 자원, 위협을 탐지합니다"

msgctxt "DT_DroneEquipment@e0@3fc"
msgid "Radiation Filter"
msgstr "방사선 필터"

msgctxt "DT_DroneEquipment@e0@445"
msgid "Consumable that protects your drone from radioactive damage for a limited time"
msgstr "제한된 시간 동안 드론을 방사능 피해로부터 보호하는 소모품"

msgctxt "DT_DroneEquipment@e0@4f5"
msgid "Nano Repair"
msgstr "나노 수리"

msgctxt "DT_DroneEquipment@e0@539"
msgid "Single-use consumable that instantly restores Drone hitpoints"
msgstr "드론의 체력을 즉시 회복시키는 일회용 소모품"

msgctxt "DT_DroneEquipment@e0@5d2"
msgid "Energy Shield"
msgstr "에너지 방어막"

msgctxt "DT_DroneEquipment@e0@618"
msgid "Absorbs a certain amount of incoming damage and regenerates over time"
msgstr "받는 피해를 일정량 흡수하며 시간이 지나면 재생됩니다"

msgctxt "DT_DroneEquipment@e0@6b5"
msgid "Micro Drone"
msgstr "마이크로 드론"

msgctxt "DT_DroneEquipment@e0@6f9"
msgid "Deploys a defence micro-drone that can shoot down incoming projectiles"
msgstr "다가오는 발사체를 격추할 수 있는 방어용 마이크로 드론을 전개합니다"

msgctxt "DT_DroneEquipment@e0@7a5"
msgid "Antimatter Lazer"
msgstr "반물질 레이저"

msgctxt "DT_DroneEquipment@e0@7ee"
msgid "Advanced and extremely powerful energy beam than can destroy enemies and meteors"
msgstr "적과 운석을 파괴할 수 있는 고도로 강력한 에너지 빔"

# ---------------------------------------------------------- DT_Levels
msgctxt "DT_Levels@e0@69"
msgid "Complete the Gate"
msgstr "게이트 완성"

msgctxt "DT_Levels@e0@1b2"
msgid "Prologue: Escape Terra System"
msgstr "프롤로그: 테라 성계 탈출"

msgctxt "DT_Levels@e0@203"
msgid "The ultramassive cosmic entity known only as <Bold>The Void</> has reached <Bold>Terra System</>, and its only a matter of time before your home planet is consumed.\r\n\r\nYou've mined all your home system's remaining resources to construct <Bold>The Gate</> - an intersteller stargate that can take you to the edge of the galaxy - and buy you some time.\r\n\r\nBut <Bold>The Gate is damaged</> and it must be <Bold>repaired</> so you can use it to escape Terra System before The Void arrives and all is lost."
msgstr "<Bold>공허</>로만 알려진 초대질량 우주 존재가 <Bold>테라 성계</>에 도달했고, 고향 행성이 삼켜지는 것은 시간 문제일 뿐입니다.\n\n당신은 고향 성계의 남은 자원을 모두 채굴하여 <Bold>게이트</>를 건설했습니다 — 은하 끝자락으로 데려갈 수 있는 항성 간 스타게이트로 시간을 벌어줍니다.\n\n하지만 <Bold>게이트가 손상</>되었고 <Bold>수리</>해야 합니다. 그래야 공허가 도달해 모든 것이 끝나기 전에 테라 성계를 탈출할 수 있습니다."

msgctxt "DT_Levels@e0@470"
msgid "Basic Manufacturing"
msgstr "기본 제조"

msgctxt "DT_Levels@e0@4bc"
msgid "Unlocks <Bold>basic production buildings, items</> and <Bold>materials</> essential for turning simple materials into useable items and parts."
msgstr "단순 재료를 사용 가능한 아이템과 부품으로 만드는 데 필수적인 <Bold>기본 생산 건물, 아이템</> 및 <Bold>재료</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@5f1"
msgid "<Bold>Matter Printers</> can convert raw materials into more complex items ready to be used in further production chains.\r\n\r\nUse the <Bold>Link</> function to automatically feed the output of your <Bold>smelters</> into matter printers to speed up production."
msgstr "<Bold>물질 프린터</>는 원자재를 더 복잡한 아이템으로 변환하여 다음 생산 단계에서 사용할 수 있게 합니다.\n\n<Bold>제련소</>의 산출물을 물질 프린터로 자동 공급하려면 <Bold>연결</> 기능을 사용해 생산을 가속하세요."

msgctxt "DT_Levels@e0@75a"
msgid "Factory Evaluation"
msgstr "공장 평가"

msgctxt "DT_Levels@e0@7f6"
msgid "Our <Bold>first priority</> should be making sure our systems survived the journey here, so we'll need to run some <Bold>tests</> on our <Bold>robotic manufacturing facilities</>..."
msgstr "<Bold>최우선 순위</>는 시스템이 여기까지의 여정을 견뎠는지 확인하는 것입니다. 따라서 <Bold>로봇 제조 시설</>에 몇 가지 <Bold>테스트</>를 실행해야 합니다..."

msgctxt "DT_Levels@e0@8df"
msgid "Please produce the <Bold>following items</> and place them in your <Bold>HUB</> to continue:\r\n\r\n{REQUIRED_ITEMS}"
msgstr "계속하려면 <Bold>다음 아이템</>을 생산해 <Bold>허브</>에 배치하세요:\n\n{REQUIRED_ITEMS}"

msgctxt "DT_Levels@e0@993"
msgid "<Bold>Good job, Station Commander</> - all systems appear operating at <Bold>100% efficiency</>.\r\n\r\nWe are now free to proceed with the <Bold>next phase</> of our operations here."
msgstr "<Bold>잘하셨습니다, 스테이션 사령관님</> — 모든 시스템이 <Bold>100% 효율</>로 작동하는 것으로 보입니다.\n\n이제 여기에서의 운영의 <Bold>다음 단계</>로 자유롭게 진행할 수 있습니다."

msgctxt "DT_Levels@e0@b6d"
msgid "Welcome to the Tau System"
msgstr "타우 성계에 오신 것을 환영합니다"

msgctxt "DT_Levels@e0@bba"
msgid "You've escaped to the mysterious <Bold>Tau System</> after your home planet is destroyed by <Bold>The Void</>: An ultramassive cosmic entity that is gradually consuming your galaxy.\r\n\r\nYour HUB contains the <Bold>genetic material</> and <Bold>uploaded personalities</> of your entire homeworld, ready to be reconstituted once you've reached a safe haven.\r\n\r\n<Bold>Your mission:</> To develop and construct an <Bold>Inter-Galactic Arkship</> you can use to escape this doomed galaxy - and The Void - forever."
msgstr "당신의 은하를 점차 삼키고 있는 초대질량 우주 존재 <Bold>공허</>에 의해 고향 행성이 파괴된 후, 당신은 신비로운 <Bold>타우 성계</>로 탈출했습니다.\n\n당신의 허브에는 고향 행성 전체의 <Bold>유전 물질</>과 <Bold>업로드된 인격체</>가 담겨 있어, 안전한 피난처에 도달하면 복원될 준비가 되어 있습니다.\n\n<Bold>임무:</> 운명 지어진 이 은하 — 그리고 공허 — 로부터 영원히 탈출하기 위한 <Bold>은하 간 방주선</>을 개발하고 건조하는 것."

msgctxt "DT_Levels@e0@df1"
msgid "Welcome to the TAU system"
msgstr "TAU 성계에 오신 것을 환영합니다"

msgctxt "DT_Levels@e0@e78"
msgid "Enhanced Manufacturing"
msgstr "강화 제조"

msgctxt "DT_Levels@e0@ec7"
msgid "Unlocks new <Bold>items, materials</> and the <Bold>Fabricator</> which can take simple items and materials and combine them to produce more complex items and simple starship parts."
msgstr "단순 아이템과 재료를 결합하여 더 복잡한 아이템과 단순한 우주선 부품을 생산할 수 있는 <Bold>가공기</>와 새로운 <Bold>아이템, 재료</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@101b"
msgid "You can now construct <Bold>Fabricators</> which can take simple items and materials and combine them to produce more complex items and simple starship parts."
msgstr "이제 단순 아이템과 재료를 결합하여 더 복잡한 아이템과 단순한 우주선 부품을 생산할 수 있는 <Bold>가공기</>를 건설할 수 있습니다."

msgctxt "DT_Levels@e0@112c"
msgid "Artifact Scanning"
msgstr "유물 스캔"

msgctxt "DT_Levels@e0@1176"
msgid "Advanced <Bold>scanning technologies</> let you extract powerful technological breakthroughs from any <Bold>alien artifacts</> you may find."
msgstr "고급 <Bold>스캔 기술</>로 발견한 <Bold>외계 유물</>에서 강력한 기술 돌파구를 추출할 수 있습니다."

msgctxt "DT_Levels@e0@1289"
msgid "The <Bold>Artifact Analyzer</> is now available from the build menu.\r\n\r\nFeed any <Bold>Alien Artifacts</> you may find into this unit to earn <Bold>Tech Points</> which can be spent on powerful upgrades and abilities."
msgstr "건설 메뉴에서 <Bold>유물 분석기</>를 사용할 수 있습니다.\n\n발견한 <Bold>외계 유물</>을 이 장치에 투입하여 <Bold>기술 포인트</>를 획득하고, 강력한 업그레이드와 능력에 사용하세요."

msgctxt "DT_Levels@e0@1444"
msgid "Energy Storage"
msgstr "에너지 저장소"

msgctxt "DT_Levels@e0@148b"
msgid "Unlocks high-capacity laminar batteries for storing any excess power your station may generate."
msgstr "스테이션이 생산하는 잉여 전력을 저장하기 위한 고용량 라미나 배터리를 잠금 해제합니다."

msgctxt "DT_Levels@e0@1569"
msgid "You have now unlocked the <Bold>Energy Storage</> module.\r\n\r\nYou can use <Bold>Energy Storage</> to store excess energy produced by your station ready to restore power levels if you lose power in your station."
msgstr "이제 <Bold>에너지 저장소</> 모듈이 잠금 해제되었습니다.\n\n<Bold>에너지 저장소</>를 사용하여 스테이션이 생산한 잉여 에너지를 저장해두고, 스테이션 전력이 손실될 경우 전력 수준을 복구할 수 있습니다."

msgctxt "DT_Levels@e0@16ca"
msgid "Deep Space Scanning"
msgstr "심우주 스캔"

msgctxt "DT_Levels@e0@175f"
msgid "Our initial surveys hinted at <Bold>vast amounts of resources</> scattered throughout this system - but now we have to <Bold>find them, and mine them</>..."
msgstr "초기 조사는 이 성계 곳곳에 흩어진 <Bold>막대한 자원</>의 존재를 시사했습니다 — 이제 우리는 <Bold>그것들을 찾아 채굴</>해야 합니다..."

msgctxt "DT_Levels@e0@182e"
msgid "We should upgrade our HUB with a <Bold>Deep Space Scanner</>. This will unlock the <Bold>System View</> and give us a clearer picture of what is around us..."
msgstr "허브를 <Bold>심우주 스캐너</>로 업그레이드해야 합니다. 그러면 <Bold>시스템 뷰</>가 잠금 해제되어 주변 상황을 더 명확하게 볼 수 있게 됩니다..."

msgctxt "DT_Levels@e0@18ff"
msgid "Please produce the <Bold>following items</> and place them in your <Bold>HUB</> to continue:\r\n\r\n{REQUIRED_ITEMS}"
msgstr "계속하려면 <Bold>다음 아이템</>을 생산해 <Bold>허브</>에 배치하세요:\n\n{REQUIRED_ITEMS}"

msgctxt "DT_Levels@e0@19b7"
msgid "<Bold>Deep Space Scanner... Deploying...</>\r\n\r\n<Bold>Great job Station Commander</>, the <Bold>System View</> can now be accessed from the <Bold>Map Screen</>...."
msgstr "<Bold>심우주 스캐너... 전개 중...</>\n\n<Bold>잘하셨습니다 스테이션 사령관님</>, 이제 <Bold>지도 화면</>에서 <Bold>시스템 뷰</>에 접근할 수 있습니다...."

msgctxt "DT_Levels@e0@1a8d"
msgid "We're already getting data back from our initial scans, but charting the <Bold>entire system</> will take some time, and there's plenty to do in the meantime."
msgstr "초기 스캔에서 이미 데이터가 들어오고 있지만, <Bold>성계 전체</>를 차트화하는 데는 시간이 걸리며, 그 동안에도 할 일이 많습니다."

msgctxt "DT_Levels@e0@1c3c"
msgid "Basic Computing"
msgstr "기본 컴퓨팅"

msgctxt "DT_Levels@e0@1c84"
msgid "Unlocks circuit boards and basic computers which are essential components widely used in advanced modules and smaller starships."
msgstr "고급 모듈과 소형 우주선에 널리 사용되는 필수 부품인 회로 기판과 기본 컴퓨터를 잠금 해제합니다."

msgctxt "DT_Levels@e0@1d8f"
msgid "Circuit boards and basic computers are now available to manufacture from the Fabricator.\r\n\r\nThese essential components are widely used in advanced modules and smaller starships."
msgstr "이제 가공기에서 회로 기판과 기본 컴퓨터를 제조할 수 있습니다.\n\n이 필수 부품들은 고급 모듈과 소형 우주선에 널리 사용됩니다."

msgctxt "DT_Levels@e0@1eb6"
msgid "Automated Ore Extraction"
msgstr "자동 광석 추출"

msgctxt "DT_Levels@e0@1f07"
msgid "Unlocks technologies which let you automate raw material extraction by constructing <Bold>Miners</> onto <Bold>Ore Nodes</> that can be found on larger asteroids."
msgstr "더 큰 소행성에서 발견할 수 있는 <Bold>광맥</>에 <Bold>채굴기</>를 건설하여 원자재 추출을 자동화하는 기술을 잠금 해제합니다."

msgctxt "DT_Levels@e0@2028"
msgid "You can now automate raw material extraction by constructing <Bold>Miners</> onto <Bold>Ore Nodes</> that can be found on larger asteroids.\r\n\r\nMiners can also be <Bold>built on</> to create mining sub-stations that serve your main station."
msgstr "이제 더 큰 소행성에서 발견할 수 있는 <Bold>광맥</>에 <Bold>채굴기</>를 건설하여 원자재 추출을 자동화할 수 있습니다.\n\n채굴기 위에 <Bold>건설</>하여 메인 스테이션을 보조하는 채굴 서브 스테이션을 만들 수도 있습니다."

msgctxt "DT_Levels@e0@21b3"
msgid "Basic Ship Construction"
msgstr "기본 함선 건조"

msgctxt "DT_Levels@e0@2203"
msgid "Unlocks the Small Shipyard which lets you construct smaller starships to satisfy more complex objectives."
msgstr "더 복잡한 목표를 달성하기 위해 작은 우주선을 건조할 수 있는 소형 조선소를 잠금 해제합니다."

msgctxt "DT_Levels@e0@2303"
msgid "The <Bold>Small Shipyard</> has now been unlocked.\r\n\r\nSmaller starships can be constructed here to satisfy orders for <Bold>starships</> and complete later objectives."
msgstr "<Bold>소형 조선소</>가 잠금 해제되었습니다.\n\n여기서 작은 우주선을 건조하여 <Bold>우주선</> 주문을 처리하고 후속 목표를 완료할 수 있습니다."

msgctxt "DT_Levels@e0@2442"
msgid "Production Overview"
msgstr "생산 개요"

msgctxt "DT_Levels@e0@248e"
msgid "Unlocks the <Bold>Production Overview Panel</> which gives you a summary of how many of each <Bold>item, material and part</> in each location your station is <Bold>producing and using</>."
msgstr "각 장소에서 스테이션이 <Bold>생산하고 사용하는</> 각 <Bold>아이템, 재료, 부품</>의 수량 요약을 제공하는 <Bold>생산 개요 패널</>을 잠금 해제합니다."

msgctxt "DT_Levels@e0@25bd"
msgid "The <Bold>Production Overview Panel</> is a useful tool for optimising your stations.\r\n\r\nThis screen gives you a summary of how many of each <Bold>item, material and part</> in each location your station is <Bold>producing and using</>, making it easier to locate shortfalls in your production lines."
msgstr "<Bold>생산 개요 패널</>은 스테이션 최적화에 유용한 도구입니다.\n\n이 화면은 각 장소에서 스테이션이 <Bold>생산하고 사용하는</> 각 <Bold>아이템, 재료, 부품</>의 수량 요약을 제공해 생산 라인의 부족분을 쉽게 찾을 수 있게 합니다."

msgctxt "DT_Levels@e0@2776"
msgid "Test Ship Construction"
msgstr "시험 함선 건조"

msgctxt "DT_Levels@e0@2801"
msgid "To perform tasks around the TAU system, we'll need <Bold>ships</> - and lots of them.\r\n\r\nWithout them we cannot <Bold>explore</> or <Bold>visit other planets</> and <Bold>locations</> - or <Bold>defend ourselves</> from hostile threats..."
msgstr "TAU 성계 곳곳에서 작업을 수행하려면 <Bold>함선</>이 필요합니다 — 그것도 많이.\n\n함선이 없으면 <Bold>탐험</>하거나 <Bold>다른 행성과 장소를 방문</>할 수 없고, 적대적 위협으로부터 <Bold>방어</>할 수도 없습니다..."

msgctxt "DT_Levels@e0@2923"
msgid "We need to <Bold>test our ship-building capabilities</> - let's start by producing the following <Bold>basic ships</>:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "<Bold>함선 건조 능력을 테스트</>해야 합니다 — 다음 <Bold>기본 함선</>들을 생산하는 것으로 시작합시다:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@29f1"
msgid "Ship telemetry is all in the green Station Commander, I think we're ready to move on with more <Bold>advanced technologies and ships now</>."
msgstr "함선 원격측정이 모두 양호합니다 스테이션 사령관님, 이제 <Bold>더 고급의 기술과 함선</>으로 넘어갈 준비가 됐다고 생각합니다."

msgctxt "DT_Levels@e0@2b8b"
msgid "Superconductors"
msgstr "초전도체"

msgctxt "DT_Levels@e0@2bd3"
msgid "Unlocks superconductors - an essential component for advanced manufacturing."
msgstr "고급 제조에 필수적인 초전도체를 잠금 해제합니다."

msgctxt "DT_Levels@e0@2ca2"
msgid "We have made a major breakthrough in the development of superconducting materials.\r\n\r\nThis will allow us to fabricate even more complex and high-technology items."
msgstr "초전도 재료 개발에 큰 돌파구를 마련했습니다.\n\n이로써 훨씬 더 복잡하고 첨단의 아이템을 제작할 수 있게 됩니다."

msgctxt "DT_Levels@e0@2db9"
msgid "Automated Logistics"
msgstr "자동화 물류"

msgctxt "DT_Levels@e0@2e05"
msgid "Unlocks robotic freighters and docks, letting you automate the movement of materials between remote parts of your station."
msgstr "스테이션의 원격 부분 간 재료 이동을 자동화할 수 있는 로봇 화물선과 도크를 잠금 해제합니다."

msgctxt "DT_Levels@e0@2efe"
msgid "You have now unlocked the <Bold>Freighter Dock</> and robotic <Bold>Freighter</>, which can be used to automate the transport of items, parts and materials between remote parts of your station - such as between Miners and your main base.\r\n\r\nConstruct one or more Docks on your station, and then build at least one Freighter from the Dock's popup menu.\r\n\r\nYou can then assign any combination of Docks for the selected Freighter to pick up and drop off items."
msgstr "이제 <Bold>화물선 도크</>와 로봇 <Bold>화물선</>이 잠금 해제되었습니다. 채굴기와 메인 기지 사이 같은 스테이션의 원격 부분 간 아이템, 부품, 재료 운송을 자동화하는 데 사용할 수 있습니다.\n\n스테이션에 도크를 하나 이상 건설한 다음, 도크 팝업 메뉴에서 화물선을 적어도 한 척 건조하세요.\n\n그런 다음 선택한 화물선이 픽업하고 배달할 도크 조합을 자유롭게 할당할 수 있습니다."

msgctxt "DT_Levels@e0@3146"
msgid "Equipment Station"
msgstr "장비 정거장"

msgctxt "DT_Levels@e0@3190"
msgid "Unlocks the Equipment Station which lets you manufacture equipment that can installed on your drone to enhance its capabilities"
msgstr "드론에 장착하여 능력을 향상시킬 수 있는 장비를 제조할 수 있는 장비 정거장을 잠금 해제합니다"

msgctxt "DT_Levels@e0@328e"
msgid "The <Bold>Equipment Station</> is now available to construct from the Build menu.\r\n\r\nThe Equipment Station lets you craft equipment that can installed on your drone to enhance its capabilities."
msgstr "이제 건설 메뉴에서 <Bold>장비 정거장</>을 건설할 수 있습니다.\n\n장비 정거장은 드론에 장착해 능력을 향상시킬 수 있는 장비를 제작할 수 있게 합니다."

msgctxt "DT_Levels@e0@3368"
msgid "AFTERBURNER"
msgstr "애프터버너"

msgctxt "DT_Levels@e0@33df"
msgid "Blueprints"
msgstr "청사진"

msgctxt "DT_Levels@e0@3422"
msgid "Unlocks the ability to a Blueprint from modules selected using the Multi-Select tool which can then be easily placed onto your station."
msgstr "다중 선택 도구로 선택한 모듈로부터 청사진을 만들고, 이를 스테이션에 쉽게 배치할 수 있는 능력을 잠금 해제합니다."

msgctxt "DT_Levels@e0@351c"
msgid "<Bold>Blueprints</> are now available from the Multi-Select tool popup menu.\r\n\r\nOnce you have selected multiple modules using the Multi-Select tool you can create a blueprint which can then be placed from the Build menu."
msgstr "이제 다중 선택 도구 팝업 메뉴에서 <Bold>청사진</>을 사용할 수 있습니다.\n\n다중 선택 도구로 여러 모듈을 선택한 후 청사진을 만들 수 있으며, 이는 건설 메뉴에서 배치할 수 있습니다."

msgctxt "DT_Levels@e0@368d"
msgid "Base Defence"
msgstr "기지 방어"

msgctxt "DT_Levels@e0@36d2"
msgid "Unlocks the Beam Turret which automates station defence against incoming meteors or enemies."
msgstr "다가오는 운석이나 적에 대한 스테이션 방어를 자동화하는 빔 포탑을 잠금 해제합니다."

msgctxt "DT_Levels@e0@37ad"
msgid "You have now unlocked the <Bold>Beam Defence Turret</> which can be constructed around your stations and sub-stations in order to automatically defend from incoming <Bold>meteors</>, <Bold>enemy drones</> and <Bold>creatures</>."
msgstr "이제 <Bold>빔 방어 포탑</>이 잠금 해제되었습니다. 스테이션과 서브 스테이션 주변에 건설하여 다가오는 <Bold>운석</>, <Bold>적 드론</>, <Bold>생명체</>로부터 자동으로 방어할 수 있습니다."

msgctxt "DT_Levels@e0@391e"
msgid "Enhanced Storage"
msgstr "강화 저장소"

msgctxt "DT_Levels@e0@3967"
msgid "Unlocks Mk 2 Storage Units which can store considerably more items, materials and parts as well as supply more linked modules due to their faster max item send speed."
msgstr "더 많은 아이템, 재료, 부품을 저장할 수 있고 최대 아이템 전송 속도가 빨라 더 많은 연결 모듈에 공급할 수 있는 Mk 2 저장 유닛을 잠금 해제합니다."

msgctxt "DT_Levels@e0@3a91"
msgid "<Bold>Mk 2 Storage Units</> have now been unlocked. \r\n\r\nThese can store considerably more items, materials and parts as well as supply more linked modules due to their faster max item send speed."
msgstr "<Bold>Mk 2 저장 유닛</>이 잠금 해제되었습니다.\n\n더 많은 아이템, 재료, 부품을 저장할 수 있고, 최대 아이템 전송 속도가 빨라 더 많은 연결 모듈에 공급할 수 있습니다."

msgctxt "DT_Levels@e0@3bc5"
msgid "Nano Repair"
msgstr "나노 수리"

msgctxt "DT_Levels@e0@3c09"
msgid "Unlocks the Nano Repair consumable which restores your Drone's hitpoints and can be crafted in the Equipment Station"
msgstr "드론의 체력을 회복시키며 장비 정거장에서 제작할 수 있는 나노 수리 소모품을 잠금 해제합니다"

msgctxt "DT_Levels@e0@3cf8"
msgid "The <Bold>Nano Repair</> equipment has now been unlocked. \r\n\r\nCraft this consumable in the Equipment Station and equip it in an equipment slot on your drone to restore hitpoints instantly when your drone is damaged."
msgstr "<Bold>나노 수리</> 장비가 잠금 해제되었습니다.\n\n장비 정거장에서 이 소모품을 제작하여 드론의 장비 슬롯에 장착하면, 드론이 피해를 입었을 때 체력을 즉시 회복할 수 있습니다."

msgctxt "DT_Levels@e0@3e51"
msgid "Scouting Surroundings"
msgstr "주변 정찰"

msgctxt "DT_Levels@e0@3edb"
msgid "Our <Bold>Deep Space Scans</> have revealed potentially resource-rich locations spread throughout the system - However we'll need to <Bold>scout these locations</> before we can decide where we should expand our facilities to next..."
msgstr "우리의 <Bold>심우주 스캔</>으로 성계 전역에 자원이 풍부할 가능성이 있는 장소들이 드러났습니다 — 그러나 시설을 다음에 확장할 곳을 결정하기 전에 <Bold>이 장소들을 정찰</>해야 합니다..."

msgctxt "DT_Levels@e0@3ff8"
msgid "To do this, we'll need to <Bold>construct</> the following <Bold>scout-ships</>:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "이를 위해 다음 <Bold>정찰선</>들을 <Bold>건조</>해야 합니다:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@40a0"
msgid "Our scouting mission has identified the presence of a <Bold>nearby Gas Giant</> that we've named <Bold>Titania...</>"
msgstr "정찰 임무는 우리가 <Bold>티타니아</>라고 명명한 <Bold>인근 가스 거성</>의 존재를 확인했습니다..."

msgctxt "DT_Levels@e0@4148"
msgid "Gas Giants are the ideal place to deploy <Bold>cloud-miners</> and automate the production of <Bold>hydrogen gas</> used in our fusion reactors and starships - so this should be our <Bold>primary objective</> for further expansion."
msgstr "가스 거성은 <Bold>구름 채굴기</>를 배치하고 융합로와 우주선에 사용되는 <Bold>수소 가스</> 생산을 자동화하기에 이상적인 장소입니다 — 따라서 이것이 추가 확장의 <Bold>주요 목표</>가 되어야 합니다."

msgctxt "DT_Levels@e0@433d"
msgid "Hydrogen Processing"
msgstr "수소 가공"

msgctxt "DT_Levels@e0@4389"
msgid "Unlocks modules and processes required for the production of Hydrogen gas used in Fusion Reactors and starship fuel."
msgstr "융합로와 우주선 연료에 사용되는 수소 가스 생산에 필요한 모듈과 공정을 잠금 해제합니다."

msgctxt "DT_Levels@e0@4498"
msgid "You now have access to <Bold>Hydrogen production</> which is used in fusion reactors and for fuelling starships.\r\n\r\n<Bold>Refineries</> can convert <Bold>water</> from <Bold>ice asteroids</> into <Bold>hydrogen gas</>, which can then be piped around your station and either stored or used in <Bold>Fusion Reactors</> to produce large amounts of power."
msgstr "이제 융합로와 우주선 연료 주입에 사용되는 <Bold>수소 생산</>이 가능합니다.\n\n<Bold>정제소</>는 <Bold>얼음 소행성</>의 <Bold>물</>을 <Bold>수소 가스</>로 변환할 수 있으며, 이를 스테이션 곳곳으로 파이프 운반하여 저장하거나 <Bold>융합로</>에서 대량의 전력을 생산할 수 있습니다."

msgctxt "DT_Levels@e0@4673"
msgid "Enhanced Ship Construction"
msgstr "강화 함선 건조"

msgctxt "DT_Levels@e0@46c6"
msgid "Unlocks more advanced starship parts and ship classes."
msgstr "더 고급의 우주선 부품과 함급을 잠금 해제합니다."

msgctxt "DT_Levels@e0@478f"
msgid "You have unlocked a higher tier of starship construction, including additional starship parts and more advanced ship classes ready to be built from the Shipyard."
msgstr "조선소에서 건조할 수 있는 추가 우주선 부품과 더 고급의 함급을 포함한 더 높은 등급의 우주선 건조를 잠금 해제했습니다."

msgctxt "DT_Levels@e0@48a3"
msgid "Fusion Technology"
msgstr "융합 기술"

msgctxt "DT_Levels@e0@48ed"
msgid "Unlocks breakthroughs in Fusion Energy production, giving you access to advanced power generation options."
msgstr "융합 에너지 생산의 돌파구를 잠금 해제하여 고급 전력 생산 옵션에 접근할 수 있게 합니다."

msgctxt "DT_Levels@e0@49de"
msgid "You have now unlocked the <Bold>Fusion Reactor</> which utilises Hydrogen Gas to sustain a fusion reaction and generate large amounts of clean energy.\r\n\r\nWe highly recommend moving from more primitive energy generation systems onto Fusion as soon as possible to secure your power needs."
msgstr "이제 수소 가스를 사용해 융합 반응을 유지하고 대량의 청정 에너지를 생성하는 <Bold>융합로</>가 잠금 해제되었습니다.\n\n전력 수요를 확보하기 위해 가능한 한 빨리 더 원시적인 에너지 생산 시스템에서 융합으로 이전할 것을 강력히 권장합니다."

msgctxt "DT_Levels@e0@4b93"
msgid "Starship Transportation"
msgstr "우주선 운송"

msgctxt "DT_Levels@e0@4be3"
msgid "Unlocks the Tug Bay and Ship Tugs which will automatically move starships around your station  - such as from a <Bold>Shipyard</> into a <Bold>Fuel Depot</> - or into a <Bold>clear space</> next to your station ready to be shipped."
msgstr "스테이션 주변에서 우주선을 자동으로 이동시키는 예인선 도크와 함선 예인선을 잠금 해제합니다 — 예를 들어 <Bold>조선소</>에서 <Bold>연료 저장고</>로, 또는 출하 준비된 스테이션 옆 <Bold>빈 공간</>으로 이동시킵니다."

msgctxt "DT_Levels@e0@4d41"
msgid "<Bold>Tug Bays</> will automatically move starships between station modules - such as from a <Bold>Shipyard</> into a <Bold>Fuel Depot</> - or into a <Bold>clear space</> next to your station ready to be shipped.\r\n\r\nUse the <Bold>Link</> function to assign a Shipyard to a Fuel Depot or a space near your station and the nearest free tug will automatically be assigned.\r\n\r\nPlease note that Tugs have a maximum range that they will pick ships up inside - hold Shift to see this."
msgstr "<Bold>예인선 도크</>는 스테이션 모듈 사이에서 우주선을 자동으로 이동시킵니다. 예를 들어 <Bold>조선소</>에서 <Bold>연료 저장고</>로, 또는 출하 준비된 스테이션 옆 <Bold>빈 공간</>으로.\n\n<Bold>연결</> 기능으로 조선소를 연료 저장고나 스테이션 근처 공간에 할당하면 가장 가까운 사용 가능한 예인선이 자동 배정됩니다.\n\n참고: 예인선은 함선을 픽업할 수 있는 최대 사정거리가 있습니다 — Shift를 눌러 확인하세요."

msgctxt "DT_Levels@e0@4f96"
msgid "Power Transmission"
msgstr "전력 전송"

msgctxt "DT_Levels@e0@4fe1"
msgid "Unlocks the Power Linker which can be used to connect the power networks of remote parts of your station."
msgstr "스테이션의 원격 부분의 전력망을 연결할 수 있는 전력 연결기를 잠금 해제합니다."

msgctxt "DT_Levels@e0@50c9"
msgid "<Bold>Power Linkers</> can be built to link the power grids of remote parts of your station - such as Miners - to your main station and centralize power generation."
msgstr "<Bold>전력 연결기</>를 건설하여 채굴기 같은 원격 스테이션 부품의 전력망을 메인 스테이션과 연결해 전력 생산을 중앙화할 수 있습니다."

msgctxt "DT_Levels@e0@51e6"
msgid "Production Overview"
msgstr "생산 개요"

msgctxt "DT_Levels@e0@5231"
msgid "Unlocks the <Bold>Production Overview Panel</> which gives you a summary of how many of each <Bold>item, material and part</> in each location your station is <Bold>producing and using</>."
msgstr "각 장소에서 스테이션이 <Bold>생산하고 사용하는</> 각 <Bold>아이템, 재료, 부품</>의 수량 요약을 제공하는 <Bold>생산 개요 패널</>을 잠금 해제합니다."

msgctxt "DT_Levels@e0@5360"
msgid "The <Bold>Production Overview Panel</> is a useful tool for optimising your stations.\r\n\r\nThis screen gives you a summary of how many of each <Bold>item, material and part</> in each location your station is <Bold>producing and using</>, making it easier to locate shortfalls in your production lines."
msgstr "<Bold>생산 개요 패널</>은 스테이션 최적화에 유용한 도구입니다.\n\n이 화면은 각 장소에서 스테이션이 <Bold>생산하고 사용하는</> 각 <Bold>아이템, 재료, 부품</>의 수량 요약을 제공해 생산 라인의 부족분을 쉽게 찾을 수 있게 합니다."

msgctxt "DT_Levels@e0@5522"
msgid "Energy Shield"
msgstr "에너지 방어막"

msgctxt "DT_Levels@e0@5568"
msgid "Unlocks an equippable Energy Shield that can be crafted in the Equipment Station and assigned to a slot on your Drone."
msgstr "장비 정거장에서 제작하여 드론 슬롯에 할당할 수 있는 장착형 에너지 방어막을 잠금 해제합니다."

msgctxt "DT_Levels@e0@5651"
msgid "You've unlocked the Energy Shield.\r\n\r\nThis can be crafted in the Machine Shop and assigned to a slot on your Drone to project a personal force-field which absorbs incoming damage and is regenerated over time."
msgstr "에너지 방어막을 잠금 해제했습니다.\n\n기계 공방에서 제작하여 드론 슬롯에 할당하면, 들어오는 피해를 흡수하고 시간이 지나면 재생되는 개인 역장을 투사할 수 있습니다."

msgctxt "DT_Levels@e0@57ac"
msgid "Fast Travel"
msgstr "빠른 이동"

msgctxt "DT_Levels@e0@57f0"
msgid "Unlocks the <Bold>Drone Teleporter</> which can be constructed at your remote bases - such as mines - and used to instantly travel between them."
msgstr "광산 같은 원격 기지에 건설하여 그 사이를 즉시 이동할 수 있는 <Bold>드론 텔레포터</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@58ff"
msgid "You have unlocked the <Bold>Drone Teleporter</>.\r\n\r\nConstruct teleporters on remote areas of your stations to instantly travel between them, and speed up time taken to traverse your factories."
msgstr "<Bold>드론 텔레포터</>가 잠금 해제되었습니다.\n\n스테이션의 원격 지역에 텔레포터를 건설하여 그 사이를 즉시 이동하고 공장을 가로지르는 시간을 단축하세요."

msgctxt "DT_Levels@e0@5a31"
msgid "Destination: Titania"
msgstr "목적지: 티타니아"

msgctxt "DT_Levels@e0@5abf"
msgid "The nearby Gas Giant - Titania - will be the perfect location to <Bold>cloud-mine</> for Hydrogen Gas.\r\n\r\nWe can use this in our <Bold>Fusion Reactors</> and to <Bold>fuel our ships</> so we can launch much longer-range missions around the system..."
msgstr "인근 가스 거성 — 티타니아 — 는 수소 가스를 <Bold>구름 채굴</>하기에 완벽한 장소가 될 것입니다.\n\n이를 <Bold>융합로</>에 사용하고 <Bold>함선의 연료</>로 사용하면 성계 곳곳에서 훨씬 더 장거리 임무를 시작할 수 있습니다..."

msgctxt "DT_Levels@e0@5bec"
msgid "We've prepared a number of <Bold>Sensor Packages</> we'd like you to drop into low-orbit around Titania, so we'll need you to build the <Bold>following ships</> to accomplish this:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "티타니아 저궤도에 투하할 <Bold>센서 패키지</>를 여러 개 준비했습니다. 이를 위해 <Bold>다음 함선</>들을 건조해 주셔야 합니다:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@5cf8"
msgid "The sensor network we deployed has determined what appears to be the <Bold>perfect location</> for us to establish a <Bold>cloud-mining station</> in the upper layers of Titania's atmosphere.\r\n\r\nThis location has been added to the <Bold>System View</> and you can now establish a <Bold>new station</> there as soon as you have the required resources."
msgstr "전개한 센서 네트워크가 티타니아 대기 상층부에 <Bold>구름 채굴 스테이션</>을 설립할 <Bold>완벽한 장소</>로 보이는 곳을 확인했습니다.\n\n이 장소가 <Bold>시스템 뷰</>에 추가되었으며, 필요한 자원이 있으면 그곳에 <Bold>새 스테이션</>을 설립할 수 있습니다."

msgctxt "DT_Levels@e0@5f15"
msgid "Destination: Titania"
msgstr "목적지: 티타니아"

msgctxt "DT_Levels@e0@5f5d"
msgid "After establishing ourselves in the <Bold>Tau System</>, we conducted tests on our manufacturing capabilities to make sure they survived the journey here.\r\n\r\nWe then produced several exploration ships and sent them out to scout the local surroundings, discovering a nearby <Bold>Gas Giant</> that we can mine for <Bold>Hydrogen Gas</> for use in our Fusion Reactors and Starship fuel."
msgstr "<Bold>타우 성계</>에 자리 잡은 후, 제조 능력이 여기까지의 여정을 견뎠는지 확인하기 위해 테스트를 수행했습니다.\n\n그런 다음 여러 탐사선을 생산해 주변을 정찰하기 위해 보냈고, 융합로와 우주선 연료에 사용할 <Bold>수소 가스</>를 채굴할 수 있는 인근 <Bold>가스 거성</>을 발견했습니다."

msgctxt "DT_Levels@e0@6151"
msgid "Portal Technology"
msgstr "포털 기술"

msgctxt "DT_Levels@e0@619b"
msgid "Unlocks the Wormhole Terminus module which can be used to link stations in different Zones together."
msgstr "서로 다른 구역의 스테이션을 연결하는 데 사용할 수 있는 웜홀 터미너스 모듈을 잠금 해제합니다."

msgctxt "DT_Levels@e0@627e"
msgid "You have now unlocked the <Bold>Wormhole Terminus</> which can be connected to a Terminus in a distant location to form a quantum gateway.\r\n\r\nItems, materials and parts can be fed into a Terminus and will appear in the Output of the gateway on the other side.\r\n\r\nYou can also connect multiple pipes to the input pipe-connectors on one Terminus and they will arrive in the same-numbered output pipe-connectors on the other side - ready to be piped elsewhere in your station."
msgstr "이제 먼 장소의 터미너스와 연결되어 양자 게이트웨이를 형성할 수 있는 <Bold>웜홀 터미너스</>가 잠금 해제되었습니다.\n\n아이템, 재료, 부품을 터미너스에 투입하면 반대편 게이트웨이의 출력으로 나타납니다.\n\n또한 한 터미너스의 입력 파이프 연결기에 여러 파이프를 연결할 수 있으며, 이는 반대편의 같은 번호 출력 파이프 연결기로 도착해 스테이션 다른 곳으로 운반될 준비가 됩니다."

msgctxt "DT_Levels@e0@64c5"
msgid "Gas Giant Operations"
msgstr "가스 거성 운영"

msgctxt "DT_Levels@e0@6512"
msgid "Unlocks new modules for taking advantage of being in the lower atmosphere of a Gas Giant."
msgstr "가스 거성 하층 대기에 있는 이점을 활용하기 위한 새 모듈들을 잠금 해제합니다."

msgctxt "DT_Levels@e0@65e6"
msgid "<Bold>Cloud Mining Stations</> let you deploy <Bold>Cloud Miners</> into the atmosphere of a gas giant and automate the collection of large amounts of hydrogen gas.\r\n\r\nConstruct <Bold>Vortex generators</> inside the atmosphere of <Bold>Gas giants</> to produce large amounts of power at very little cost."
msgstr "<Bold>구름 채굴 스테이션</>은 <Bold>구름 채굴기</>를 가스 거성의 대기 중에 배치하여 대량의 수소 가스 수집을 자동화합니다.\n\n<Bold>가스 거성</>의 대기 안에 <Bold>볼텍스 발전기</>를 건설하면 매우 적은 비용으로 대량의 전력을 생산할 수 있습니다."

msgctxt "DT_Levels@e0@678b"
msgid "High Explosives"
msgstr "고폭약"

msgctxt "DT_Levels@e0@67d3"
msgid "Unlocks new processes for converting Nitratium into explosive compounds ready to be used in military applications."
msgstr "니트라튬을 군사용으로 사용 가능한 폭발성 화합물로 변환하는 새 공정을 잠금 해제합니다."

msgctxt "DT_Levels@e0@68c8"
msgid "You can now synthesize the highly explosive bio-compound <Bold>Nitrox</>, which can be produced by refining the <Bold>Nitratium</> recovered from gas-giant flora and fauna and combining it in a <Bold>Refinery</> with <Bold>Oxygen</> extracted from <Bold>Water</>."
msgstr "이제 강력한 폭발성 생물 화합물 <Bold>나이트록스</>를 합성할 수 있습니다. 가스 거성의 동식물에서 회수한 <Bold>니트라튬</>을 정제하고 <Bold>물</>에서 추출한 <Bold>산소</>와 <Bold>정제소</>에서 결합하여 생산할 수 있습니다."

msgctxt "DT_Levels@e0@6a46"
msgid "Starship Fuelling"
msgstr "우주선 연료 주입"

msgctxt "DT_Levels@e0@6a90"
msgid "Unlocks the Fuel Depot which can be used to fuel starships with Hydrogen and complete higher-level objectives."
msgstr "수소로 우주선에 연료를 주입하고 더 높은 단계의 목표를 완료할 수 있는 연료 저장고를 잠금 해제합니다."

msgctxt "DT_Levels@e0@6b75"
msgid "You have unlocked the <Bold>Fuel Depot</> which can be supplied with Hydrogen Gas and fuel waiting starships.\r\n\r\nYou can <Fuelled>fuel</> a starship by dragging it into an empty <Bold>Fuel Depot</> and fuelling will begin automatically.\r\n\r\nYou can also link a Shipyard to a Fuel Depot to have a free tug automatically move ships into the depot."
msgstr "수소 가스를 공급받아 대기 중인 우주선에 연료를 주입할 수 있는 <Bold>연료 저장고</>가 잠금 해제되었습니다.\n\n빈 <Bold>연료 저장고</>에 우주선을 끌어 넣으면 <Fuelled>연료 주입</>이 자동으로 시작됩니다.\n\n조선소를 연료 저장고에 연결하면 사용 가능한 예인선이 자동으로 함선을 저장고로 이동시킵니다."

msgctxt "DT_Levels@e0@6d44"
msgid "Enhanced Smelting"
msgstr "강화 제련"

msgctxt "DT_Levels@e0@6d8e"
msgid "Unlocks the Mk 2 Smelter which can process raw materials at a faster rate and increase production."
msgstr "원자재를 더 빠른 속도로 처리하고 생산을 증가시키는 Mk 2 제련소를 잠금 해제합니다."

msgctxt "DT_Levels@e0@6e74"
msgid "<Bold>Mk 2 Smelters</> have now been unlocked. \r\n\r\nThese can process raw materials into usable metals and other materials at a higher rate and increase the output of your factory immensely."
msgstr "<Bold>Mk 2 제련소</>가 잠금 해제되었습니다.\n\n원자재를 사용 가능한 금속과 기타 재료로 더 빠른 속도로 처리하여 공장의 출력을 크게 증가시킵니다."

msgctxt "DT_Levels@e0@6fae"
msgid "Enhanced Ore Extraction"
msgstr "강화 광석 추출"

msgctxt "DT_Levels@e0@6ffe"
msgid "Unlocks the Mk 2 Miner which can extract ores at a faster rate and increase factory output."
msgstr "광석을 더 빠른 속도로 추출하고 공장 출력을 증가시키는 Mk 2 채굴기를 잠금 해제합니다."

msgctxt "DT_Levels@e0@70db"
msgid "<Bold>Mk 2 Miners</> have now been unlocked. \r\n\r\nThese can extract raw materials at a higher rate and increase the output of your factory immensely."
msgstr "<Bold>Mk 2 채굴기</>가 잠금 해제되었습니다.\n\n원자재를 더 빠른 속도로 추출하여 공장의 출력을 크게 증가시킵니다."

msgctxt "DT_Levels@e0@71e5"
msgid "Missile Launcher"
msgstr "미사일 발사기"

msgctxt "DT_Levels@e0@722e"
msgid "Unlocks an equippable <Bold>Missile Launcher</> that can be crafted in the <Bold>Equipment Station</> and assigned to a slot on your Drone."
msgstr "<Bold>장비 정거장</>에서 제작하여 드론 슬롯에 할당할 수 있는 장착형 <Bold>미사일 발사기</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@7334"
msgid "You've unlocked the <Bold>Missile Launcher</>.\r\n\r\nThis can be crafted in the <Bold>Equipment Station</> and assigned to a slot on your Drone to fire <Bold>explosive-tipped missiles</> at enemies."
msgstr "<Bold>미사일 발사기</>를 잠금 해제했습니다.\n\n<Bold>장비 정거장</>에서 제작하여 드론 슬롯에 할당하면 적에게 <Bold>폭발성 탄두 미사일</>을 발사할 수 있습니다."

msgctxt "DT_Levels@e0@747e"
msgid "Going Further"
msgstr "더 멀리"

msgctxt "DT_Levels@e0@7514"
msgid "Things are progressing well here, but we're running low on <Bold>raw resources</> so we need to find <Bold>additional mining locations</> we can exploit..."
msgstr "여기는 잘 진행되고 있지만, <Bold>원자재</>가 부족해지고 있어 활용할 수 있는 <Bold>추가 채굴 장소</>를 찾아야 합니다..."

msgctxt "DT_Levels@e0@75e3"
msgid "To explore further afield we'll need to dispatch scout-ships which have been <Bold>fuelled</>, as well as <Bold>tanker-ships</> which can refuel them on their journey..."
msgstr "더 먼 곳을 탐사하려면 <Bold>연료가 주입된</> 정찰선과 함께 그것들을 여정 중에 재급유할 수 있는 <Bold>유조선</>도 파견해야 합니다..."

msgctxt "DT_Levels@e0@76c0"
msgid "Let us know when you've produced the <Bold>following ships</>:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "<Bold>다음 함선</>들을 생산하시면 알려주세요:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@775a"
msgid "Our expedition has discovered a <Bold>resource-rich mining location</> in the secondary Asteroid Belt which will greatly increase our supply of raw materials and enable us to expand even further.\r\n\r\nThis location has been added to the <Bold>System View</> and you can now establish a <Bold>new station</> there as soon as you have the required resources."
msgstr "우리 탐사대는 2차 소행성대에서 <Bold>자원이 풍부한 채굴 장소</>를 발견했습니다. 이는 원자재 공급을 크게 증가시키고 더 확장할 수 있게 해줍니다.\n\n이 장소가 <Bold>시스템 뷰</>에 추가되었으며, 필요한 자원이 있으면 그곳에 <Bold>새 스테이션</>을 설립할 수 있습니다."

msgctxt "DT_Levels@e0@79e8"
msgid "Alloy Production"
msgstr "합금 생산"

msgctxt "DT_Levels@e0@7a31"
msgid "Unlocks the Plasma Forge which can be used to fuse metallic elements together into superstrong alloys."
msgstr "금속 원소를 융합해 초강력 합금으로 만들 수 있는 플라즈마 용광로를 잠금 해제합니다."

msgctxt "DT_Levels@e0@7b26"
msgid "The <Bold>Plasma Forge</> has now been unlocked. Use this to combine elements together to form advanced <Bold>alloys</>."
msgstr "<Bold>플라즈마 용광로</>가 잠금 해제되었습니다. 이를 사용하여 원소를 결합해 고급 <Bold>합금</>을 제작하세요."

msgctxt "DT_Levels@e0@7c1a"
msgid "Advanced Ship Construction"
msgstr "고급 함선 건조"

msgctxt "DT_Levels@e0@7c6d"
msgid "Unlocks more advanced starship parts and ship classes."
msgstr "더 고급의 우주선 부품과 함급을 잠금 해제합니다."

msgctxt "DT_Levels@e0@7d36"
msgid "You have unlocked a higher tier of starship construction, including additional starship parts and more advanced ship classes ready to be built from the Shipyard."
msgstr "조선소에서 건조할 수 있는 추가 우주선 부품과 더 고급의 함급을 포함한 더 높은 등급의 우주선 건조를 잠금 해제했습니다."

msgctxt "DT_Levels@e0@7e62"
msgid "Bio-Extractor"
msgstr "바이오 추출기"

msgctxt "DT_Levels@e0@7ea8"
msgid "Unlocks the Bio-Extractor which can automate the extraction of biological compounds from larger flora and fauna."
msgstr "더 큰 동식물에서 생물학적 화합물 추출을 자동화할 수 있는 바이오 추출기를 잠금 해제합니다."

msgctxt "DT_Levels@e0@7f97"
msgid "The <Bold>Bio Extractor</> can be used to automate the extraction of <Bold>Nitratium</> from large gas-giant flora in order to automate large-scale <Bold>Nitrox</> production."
msgstr "<Bold>바이오 추출기</>를 사용하여 가스 거성의 거대 식물에서 <Bold>니트라튬</> 추출을 자동화하고, 대규모 <Bold>나이트록스</> 생산을 자동화할 수 있습니다."

msgctxt "DT_Levels@e0@80d6"
msgid "Enhanced Logistics"
msgstr "강화 물류"

msgctxt "DT_Levels@e0@8121"
msgid "Unlocks the Mk 2 Freighter Dock and Mk 2 Freighter which can transport more items as well as liquids and gases around your station."
msgstr "스테이션 주변에서 더 많은 아이템뿐만 아니라 액체와 기체까지 운송할 수 있는 Mk 2 화물선 도크와 Mk 2 화물선을 잠금 해제합니다."

msgctxt "DT_Levels@e0@824a"
msgid "<Bold>Mk 2 Freighter Docks</> can store considerably more items ready for transport, as well as gases and liquids. They can also output items at a faster rate, letting you link more modules to them and avoid bottlenecks.\r\n\r\n<Bold>Mk 2 Freighters</> can be constructed from Mk 2 Docks, and these can also transport more items at higher speeds, as well as gases and liquids too."
msgstr "<Bold>Mk 2 화물선 도크</>는 운송 준비가 된 아이템과 함께 기체와 액체도 훨씬 더 많이 저장할 수 있습니다. 또한 아이템을 더 빠른 속도로 출력할 수 있어 더 많은 모듈을 연결하고 병목 현상을 피할 수 있습니다.\n\n<Bold>Mk 2 화물선</>은 Mk 2 도크에서 건조할 수 있으며, 더 많은 아이템을 더 빠른 속도로 운송할 수 있고 기체와 액체도 운송할 수 있습니다."

msgctxt "DT_Levels@e0@8453"
msgid "Expanded Blueprints"
msgstr "확장 청사진"

msgctxt "DT_Levels@e0@849f"
msgid "Enables larger blueprint area and a higher maximum number of modules inside a blueprint"
msgstr "더 큰 청사진 영역과 청사진 안의 더 많은 최대 모듈 수를 가능하게 합니다"

msgctxt "DT_Levels@e0@8569"
msgid "You have unlocked expanded blueprints, which lets you select and add <Bold>more modules</> to a blueprint, as well as an expanded blueprint <Bold>area</>."
msgstr "확장 청사진을 잠금 해제했습니다. 청사진에 <Bold>더 많은 모듈</>을 선택해 추가할 수 있고, 확장된 청사진 <Bold>영역</>도 사용할 수 있습니다."

msgctxt "DT_Levels@e0@8694"
msgid "Recycler"
msgstr "재활용기"

msgctxt "DT_Levels@e0@86d5"
msgid "Unlocks the <Bold>Recycler</> which you can feed unwanted resources into in exhange for <Bold>Tokens</> that you can spend on various rewards."
msgstr "원치 않는 자원을 투입해 다양한 보상에 사용할 수 있는 <Bold>토큰</>으로 교환할 수 있는 <Bold>재활용기</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@87e2"
msgid "The <Bold>Recycler</> has been unlocked.\r\n\r\nFeed unwanted resources into this module in exchange for <Bold>Tokens</> that you can spend on various rewards."
msgstr "<Bold>재활용기</>가 잠금 해제되었습니다.\n\n원치 않는 자원을 이 모듈에 투입하여 다양한 보상에 사용할 수 있는 <Bold>토큰</>으로 교환하세요."

msgctxt "DT_Levels@e0@8910"
msgid "Alternate Recipe Research"
msgstr "대체 제작법 연구"

msgctxt "DT_Levels@e0@8962"
msgid "Unlocks the <Bold>Laboratory</> and the ability to research <Bold>alternative recipes</> for producing various items, materials and parts"
msgstr "<Bold>연구소</>와 다양한 아이템, 재료, 부품을 생산하기 위한 <Bold>대체 제작법</> 연구 능력을 잠금 해제합니다"

msgctxt "DT_Levels@e0@8a62"
msgid "The <Bold>Laboratory</> has been unlocked.\r\n\r\nFeed items, parts and materials into this module for analysis and you can unlock <Bold>alternative</> and <Bold>more efficient</> recipes for producing them."
msgstr "<Bold>연구소</>가 잠금 해제되었습니다.\n\n분석을 위해 아이템, 부품, 재료를 이 모듈에 투입하면 그것들을 생산하기 위한 <Bold>대체</> 및 <Bold>더 효율적인</> 제작법을 잠금 해제할 수 있습니다."

msgctxt "DT_Levels@e0@8bcf"
msgid "Destination: Glacialis"
msgstr "목적지: 글라시알리스"

msgctxt "DT_Levels@e0@8c6c"
msgid "The <Bold>Ice Planet Glacialis</> is the perfect location to automate the harvesting of <Bold>water ice</> for use in oxygen production and other industries..."
msgstr "<Bold>얼음 행성 글라시알리스</>는 산소 생산과 기타 산업에 사용할 <Bold>얼음</> 채집을 자동화하기에 완벽한 장소입니다..."

msgctxt "DT_Levels@e0@8d3f"
msgid "However, the rings of this planet are highly <Bold>unstable</>, so we'll need to deploy more <Bold>advanced ships and sensors</> to locate a stable zone we can establish a station within..."
msgstr "하지만 이 행성의 고리는 매우 <Bold>불안정</>하므로, 스테이션을 설립할 수 있는 안정 구역을 찾기 위해 더 <Bold>고급 함선과 센서</>를 배치해야 합니다..."

msgctxt "DT_Levels@e0@8e30"
msgid "<Bold>Neutron Explorers</> are perfect for this task, and we can use the new <Bold>Stratos Prospecters</> to retrieve samples from deep within the ring. Please produce the following:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "<Bold>중성자 탐사선</>이 이 작업에 적합하며, 새 <Bold>스트라토스 탐사선</>을 사용해 고리 깊숙한 곳에서 샘플을 회수할 수 있습니다. 다음을 생산해 주세요:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@8f42"
msgid "We believe that we've identified a stable zone deep within the rings of <Bold>Glacialis</> that will enable us to automate the mining of Water Ice to be used in our production chains.\r\n\r\nThis location has been added to the <Bold>System View</> and you can now establish a <Bold>new station</> there as soon as you have the required resources."
msgstr "<Bold>글라시알리스</>의 고리 깊숙한 곳에서 안정 구역을 확인한 것으로 보이며, 이를 통해 생산 체인에 사용할 얼음 채굴을 자동화할 수 있습니다.\n\n이 장소가 <Bold>시스템 뷰</>에 추가되었으며, 필요한 자원이 있으면 그곳에 <Bold>새 스테이션</>을 설립할 수 있습니다."

msgctxt "DT_Levels@e0@91b4"
msgid "Advanced Manufacturing"
msgstr "고급 제조"

msgctxt "DT_Levels@e0@9203"
msgid "Unlocks highly advanced manufacturing processes providing access to new items, materials and parts."
msgstr "새로운 아이템, 재료, 부품에 접근할 수 있는 고도로 진보한 제조 공정을 잠금 해제합니다."

msgctxt "DT_Levels@e0@9305"
msgid "<Bold>Manufactories</> can now be constructed from the Build menu.\r\n\r\nThese giant production machines can produce some of the largest and most complex parts and items you'll need for more advanced modules and starships."
msgstr "이제 건설 메뉴에서 <Bold>제조소</>를 건설할 수 있습니다.\n\n이 거대한 생산 기계는 더 고급 모듈과 우주선에 필요한 가장 크고 복잡한 부품과 아이템 일부를 생산할 수 있습니다."

msgctxt "DT_Levels@e0@948c"
msgid "Advanced Computing"
msgstr "고급 컴퓨팅"

msgctxt "DT_Levels@e0@94d7"
msgid "Unlocks ultra-high-speed supercomputing technologies which power larger starships and advanced station modules."
msgstr "더 큰 우주선과 고급 스테이션 모듈을 구동하는 초고속 슈퍼컴퓨팅 기술을 잠금 해제합니다."

msgctxt "DT_Levels@e0@95c9"
msgid "You've now unlocked Supercomputers which are an essential component in the most advanced module and starship production."
msgstr "이제 가장 고급의 모듈과 우주선 생산에 필수적인 슈퍼컴퓨터를 잠금 해제했습니다."

msgctxt "DT_Levels@e0@96be"
msgid "Heavy Ship Construction"
msgstr "중형 함선 건조"

msgctxt "DT_Levels@e0@970e"
msgid "Unlocks the ability to construct larger ship classes."
msgstr "더 큰 함급을 건조할 수 있게 합니다."

msgctxt "DT_Levels@e0@97e2"
msgid "<Bold>Medium Shipyards</> are now available for you to fulfil ever-larger and more complex starship orders.\r\n\r\nNote: Larger ships may require <Bold>Micro Fusion Reactors</> to be installed. These ships must be fuelled quickly after completion to avoid catastrophic reactor meltdown."
msgstr "<Bold>중형 조선소</>를 사용할 수 있어 점점 더 크고 복잡한 우주선 주문을 처리할 수 있습니다.\n\n참고: 더 큰 우주선은 <Bold>마이크로 융합로</>를 설치해야 할 수 있습니다. 이러한 우주선은 완성 후 빠르게 연료를 주입해야 원자로 멜트다운을 방지할 수 있습니다."

msgctxt "DT_Levels@e0@9995"
msgid "Enhanced Base Defence"
msgstr "강화 기지 방어"

msgctxt "DT_Levels@e0@99e3"
msgid "Unlocks more powerful automated base defences."
msgstr "더 강력한 자동 기지 방어를 잠금 해제합니다."

msgctxt "DT_Levels@e0@9a90"
msgid "Enhanced Base Defences are now available for construction.\r\n\r\nWe recommend building enhanced <Bold>Missile Defence Turrets</> on your most vulnerable stations to safely defend against larger groups of enemies."
msgstr "강화 기지 방어 시설을 건설할 수 있습니다.\n\n가장 취약한 스테이션에 강화된 <Bold>미사일 방어 포탑</>을 건설하여 더 큰 적 무리로부터 안전하게 방어할 것을 권장합니다."

msgctxt "DT_Levels@e0@9bf5"
msgid "Advanced Storage"
msgstr "고급 저장소"

msgctxt "DT_Levels@e0@9c3e"
msgid "Unlocks the <Bold>Mk 3 Storage Unit</> and <Bold>Mk 2 Storage Tank</> which can store even more items and outputs items at a faster rate."
msgstr "더 많은 아이템을 저장하고 더 빠른 속도로 출력할 수 있는 <Bold>Mk 3 저장 유닛</>과 <Bold>Mk 2 저장 탱크</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@9d68"
msgid "<Bold>Mk 3 Storage Units</> and <Bold>Mk 2 Storage Tanks</> have now been unlocked. \r\n\r\nThese can store considerably more items, materials and parts as well as supply more linked modules due to their faster max item send speed."
msgstr "<Bold>Mk 3 저장 유닛</>과 <Bold>Mk 2 저장 탱크</>가 잠금 해제되었습니다.\n\n더 많은 아이템, 재료, 부품을 저장할 수 있고, 최대 아이템 전송 속도가 빨라 더 많은 연결 모듈에 공급할 수 있습니다."

msgctxt "DT_Levels@e0@9ebc"
msgid "Defence Micro-Drone"
msgstr "방어 마이크로 드론"

msgctxt "DT_Levels@e0@9f08"
msgid "Unlocks the Micro Drone which when equipped will shoot down incoming projectiles."
msgstr "장착하면 다가오는 발사체를 격추하는 마이크로 드론을 잠금 해제합니다."

msgctxt "DT_Levels@e0@9fdc"
msgid "The <Bold>Defence Micro Drone</> has now been unlocked. \r\n\r\nThis can be crafted in the Equipment Station and when equipped can shoot down incoming projectiles."
msgstr "<Bold>방어 마이크로 드론</>이 잠금 해제되었습니다.\n\n장비 정거장에서 제작할 수 있으며, 장착하면 다가오는 발사체를 격추할 수 있습니다."

msgctxt "DT_Levels@e0@a0f5"
msgid "Expansion Protocol"
msgstr "확장 프로토콜"

msgctxt "DT_Levels@e0@a1a0"
msgid "Its time to <Bold>expand our operations</> here once again, Station Commander, and for that we'll need more <Bold>raw materials...</>"
msgstr "다시 한 번 <Bold>운영을 확장</>할 시간입니다, 스테이션 사령관님. 이를 위해 더 많은 <Bold>원자재</>가 필요합니다..."

msgctxt "DT_Levels@e0@a259"
msgid "We propose to dispatch <Bold>additional scouting missions</> to the following locations:\r\n\r\nOne mission will explore the far distant, <Bold>third Asteroid Belt</>, while the other mission will investigate some <Bold>strange energy readings</> we've detected from the <Bold>Lava Planet</> we've named <Bold>Cerberus...</>"
msgstr "다음 장소들에 <Bold>추가 정찰 임무</>를 파견할 것을 제안합니다:\n\n한 임무는 멀리 떨어진 <Bold>3차 소행성대</>를 탐사하고, 다른 임무는 우리가 <Bold>케르베로스</>라고 명명한 <Bold>용암 행성</>에서 감지한 <Bold>이상한 에너지 신호</>를 조사할 것입니다..."

msgctxt "DT_Levels@e0@a3cd"
msgid "These are <Bold>hazardous, long-distance missions</>, so we we'll need additional <Bold>heavy ships</> to successfully carry them out. Please construct the <Bold>following ships:</>\r\n\r\n{REQUIRED_SHIPS}"
msgstr "이는 <Bold>위험하고 장거리인 임무</>이므로, 성공적으로 수행하려면 추가 <Bold>중형 함선</>이 필요합니다. <Bold>다음 함선들을 건조</>해 주세요:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@a4de"
msgid "We have <Bold>good news</> and <Bold>bad news</> Commander: The expedition to the most distant Asteroid Belt was a success, and this location has been added to your <Bold>System View</> for immediate expansion..."
msgstr "<Bold>좋은 소식</>과 <Bold>나쁜 소식</>이 있습니다 사령관님: 가장 먼 소행성대로의 탐사는 성공했고, 이 장소가 즉각 확장을 위해 <Bold>시스템 뷰</>에 추가되었습니다..."

msgctxt "DT_Levels@e0@a5e6"
msgid "However, we have <Bold>lost all contact</> with the ships sent to the <Bold>Lava Planet Cerberus</>, and we fear that they have all been <Bold>destroyed</> by an <Bold>unknown hostile force</>. \r\n\r\nThe <Bold>energy readings</> coming from this location cannot be ignored however, so we will have to <Bold>mount another mission</> to this location in the future."
msgstr "그러나 <Bold>용암 행성 케르베로스</>로 보낸 함선들과 <Bold>모든 통신이 끊겼고</>, <Bold>알 수 없는 적대 세력</>에 의해 모두 <Bold>파괴</>된 것이 우려됩니다.\n\n그러나 이 장소에서 오는 <Bold>에너지 신호</>는 무시할 수 없으므로, 향후 이 장소에 <Bold>또 다른 임무를 시행</>해야 할 것입니다."

msgctxt "DT_Levels@e0@a80f"
msgid "Destination: Glacialis"
msgstr "목적지: 글라시알리스"

msgctxt "DT_Levels@e0@a859"
msgid "After expanding into the Gas Giant Titania, we discovered that the rings of a nearby Ice Planet contain everything we need to expand and automate our water-to-oxygen pipeline.\r\n\r\nIf we hope to mass-produce explosives and weapons, this is going to have to be our next destination."
msgstr "가스 거성 티타니아로 확장한 후, 인근 얼음 행성의 고리에 물-산소 파이프라인을 확장하고 자동화하는 데 필요한 모든 것이 있다는 사실을 발견했습니다.\n\n폭발물과 무기를 대량 생산하려면, 이곳이 다음 목적지가 되어야 합니다."

msgctxt "DT_Levels@e0@a9ee"
msgid "Basic Ammunition Production"
msgstr "기본 탄약 생산"

msgctxt "DT_Levels@e0@aa42"
msgid "Unlocks the ability to produce warheads, missiles and the Ammo Depot to install them into military-grade starships."
msgstr "탄두, 미사일과 그것들을 군용 우주선에 설치할 수 있는 탄약 저장고 생산 능력을 잠금 해제합니다."

msgctxt "DT_Levels@e0@ab40"
msgid "You have now unlocked the <Bold>Ammo Factory</> and <Bold>Ammo Depot</>.\r\n\r\n<Armed>Ship Ammo</> is produced in the <Bold>Ammo Factory</> and loaded into a ship from the <Bold>Ammo Depot</>.\r\n\r\nAs with Fuel Depots, you can link a module to an Ammo Depot and nearby tugs will automatically transport ships between them."
msgstr "이제 <Bold>탄약 공장</>과 <Bold>탄약 저장고</>가 잠금 해제되었습니다.\n\n<Armed>함선 탄약</>은 <Bold>탄약 공장</>에서 생산되며 <Bold>탄약 저장고</>에서 함선에 장전됩니다.\n\n연료 저장고와 마찬가지로, 모듈을 탄약 저장고에 연결하면 인근 예인선이 자동으로 함선을 그 사이로 운송합니다."

msgctxt "DT_Levels@e0@aced"
msgid "Military Grade Starships"
msgstr "군용 우주선"

msgctxt "DT_Levels@e0@ad3e"
msgid "Unlocks the ability to construct military starships."
msgstr "군용 우주선을 건조할 수 있게 합니다."

msgctxt "DT_Levels@e0@ae0d"
msgid "You have now unlocked Military Starships which must be provided with the required Ammo.\r\n\r\nAmmo is produced in the Ammo Factory, and can be deployed from the Ammo Depot."
msgstr "이제 필요한 탄약을 공급받아야 하는 군용 우주선을 잠금 해제했습니다.\n\n탄약은 탄약 공장에서 생산되며, 탄약 저장고에서 배치할 수 있습니다."

msgctxt "DT_Levels@e0@af50"
msgid "Advanced Ore Extraction"
msgstr "고급 광석 추출"

msgctxt "DT_Levels@e0@afa0"
msgid "Unlocks the <Bold>Mk 3 Miner</> and <Bold>Mk 2 Bio-Extractor</> to further increase maximum raw material extraction rate."
msgstr "최대 원자재 추출 속도를 더 증가시키는 <Bold>Mk 3 채굴기</>와 <Bold>Mk 2 바이오 추출기</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@b0b1"
msgid "<Bold>Mk 3 Miners</> and <Bold>Mk 2 Bio-Extractors</> have now been unlocked. \r\n\r\nThese can extract raw materials at a higher rate and increase the output of your factory immensely."
msgstr "<Bold>Mk 3 채굴기</>와 <Bold>Mk 2 바이오 추출기</>가 잠금 해제되었습니다.\n\n원자재를 더 빠른 속도로 추출하여 공장의 출력을 크게 증가시킵니다."

msgctxt "DT_Levels@e0@b1dd"
msgid "Advanced Fuelling"
msgstr "고급 연료 주입"

msgctxt "DT_Levels@e0@b227"
msgid "Unlocks the Mk 2 Fuel Depot which has a faster fuel transfer rate and fuel larger starships more efficiently."
msgstr "더 빠른 연료 전달 속도를 가지고 더 큰 우주선에 더 효율적으로 연료를 주입할 수 있는 Mk 2 연료 저장고를 잠금 해제합니다."

msgctxt "DT_Levels@e0@b323"
msgid "The <Bold>Mk 2 Fuel Depot</> has now been unlocked.\r\n\r\nThis module has a faster fuel transfer rate and can fuel larger starships more efficiently."
msgstr "<Bold>Mk 2 연료 저장고</>가 잠금 해제되었습니다.\n\n이 모듈은 연료 전달 속도가 더 빠르고 더 큰 우주선에 더 효율적으로 연료를 주입할 수 있습니다."

msgctxt "DT_Levels@e0@b42d"
msgid "Advanced Logistics"
msgstr "고급 물류"

msgctxt "DT_Levels@e0@b478"
msgid "Unlocks the Mk 3 Freighter Dock and Mk 3 Freighter which can transport items even faster around your stations."
msgstr "스테이션 주변에서 아이템을 훨씬 더 빠르게 운송할 수 있는 Mk 3 화물선 도크와 Mk 3 화물선을 잠금 해제합니다."

msgctxt "DT_Levels@e0@b58c"
msgid "<Bold>Mk 3 Freighter Docks</> can store considerably more items ready for transport. They can also output items at a faster rate, letting you link more modules to them and avoid bottlenecks.\r\n\r\n<Bold>Mk 3 Freighters</> can be constructed from Mk 3 Docks, and these can also transport more items at higher speeds, as well as having a mounted Beam Turret for defence against nearby enemies."
msgstr "<Bold>Mk 3 화물선 도크</>는 운송 준비가 된 아이템을 훨씬 더 많이 저장할 수 있습니다. 또한 아이템을 더 빠른 속도로 출력할 수 있어 더 많은 모듈을 연결하고 병목 현상을 피할 수 있습니다.\n\n<Bold>Mk 3 화물선</>은 Mk 3 도크에서 건조할 수 있으며, 더 많은 아이템을 더 빠른 속도로 운송할 수 있고 인근 적에 대한 방어를 위해 빔 포탑이 장착되어 있습니다."

msgctxt "DT_Levels@e0@b77a"
msgid "Cerberus Beach-head"
msgstr "케르베로스 교두보"

msgctxt "DT_Levels@e0@b822"
msgid "We've still had <Bold>no contact</> from the mission sent to the <Bold>Lava Planet Cerberus</>, so we have no choice but to make sure that any future operations sent to this area can defend themselves against <Bold>hostile threats...</>"
msgstr "<Bold>용암 행성 케르베로스</>로 보낸 임무로부터 여전히 <Bold>통신이 없으므로</>, 이 지역으로 보내는 미래의 모든 작전이 <Bold>적대적 위협</>에 맞서 스스로를 방어할 수 있도록 보장하는 것 외에 선택의 여지가 없습니다..."

msgctxt "DT_Levels@e0@b942"
msgid "Energy readings point to this area being a potential source of <Bold>Exotic Matter</> however, so we must mount <Bold>another expedition</> to investigate this further..."
msgstr "그러나 에너지 신호는 이 지역이 <Bold>이그조틱 물질</>의 잠재적 공급원임을 시사하므로, 이를 더 조사하기 위해 <Bold>또 다른 탐사대</>를 시행해야 합니다..."

msgctxt "DT_Levels@e0@ba20"
msgid "With this in mind we recommend that we assemble a <Bold>military force</> to explore this area and find the source of the exotic readings emanating from the region. Please build the following ships:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "이를 염두에 두고, 이 지역을 탐사하고 그 지역에서 발산되는 이그조틱 신호의 원천을 찾기 위해 <Bold>군사력</>을 결집할 것을 권장합니다. 다음 함선들을 건조해 주세요:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@bb42"
msgid "Our assault mission to <Bold>Cerberus</> has been able to establish a <Bold>beach-head</> in orbit around the planet, and the source of the energy readings has been identified:\r\n\r\nA vast <Bold>debris field</> made from the <Bold>wrecks of countless starships</> orbits the planet - we believe these are the remnants of an ancient war between unknown forces."
msgstr "<Bold>케르베로스</>로의 공격 임무는 행성 궤도에 <Bold>교두보</>를 설립하는 데 성공했고, 에너지 신호의 원천이 확인되었습니다:\n\n행성 궤도에는 <Bold>수많은 우주선의 잔해</>로 이루어진 광대한 <Bold>잔해 지대</>가 있습니다 — 우리는 이것이 알 수 없는 세력 간의 고대 전쟁의 잔재라고 봅니다."

msgctxt "DT_Levels@e0@bcdb"
msgid "Our forces have confirmed the presence of <Bold>Exotic Matter</> in and around these wrecks, which will be essential if we want to begin the production of <Bold>Antimatter</>.\r\n\r\nOur forces also discovered an ancient <Bold>robot production facility</> within this area, and we believe this is where most of the <Bold>hostile robots</> we've encountered in this system are coming from."
msgstr "우리 부대는 이 잔해 안과 주변에서 <Bold>이그조틱 물질</>의 존재를 확인했으며, 이는 <Bold>반물질</> 생산을 시작하려면 필수적입니다.\n\n또한 이 지역 안에서 고대 <Bold>로봇 생산 시설</>을 발견했으며, 이것이 이 성계에서 마주친 대부분의 <Bold>적대 로봇</>의 출처라고 봅니다."

msgctxt "DT_Levels@e0@bf63"
msgid "Uranium Processing"
msgstr "우라늄 가공"

msgctxt "DT_Levels@e0@bfae"
msgid "Unlocks processes for processing <Bold>radioactive raw materials</> into useable items."
msgstr "<Bold>방사성 원자재</>를 사용 가능한 아이템으로 처리하는 공정을 잠금 해제합니다."

msgctxt "DT_Levels@e0@c080"
msgid "You have now unlocked the ability to process <Bold>Uranium</>.\r\n\r\nThis is a <Bold>highly radioactive</> substance that will <Bold>damage your drone</> unless you have <Bold>Radiation Filters</> installed."
msgstr "이제 <Bold>우라늄</> 처리 능력이 잠금 해제되었습니다.\n\n이는 <Bold>강한 방사능</> 물질로, <Bold>방사선 필터</>가 설치되어 있지 않으면 <Bold>드론에 피해</>를 입힙니다."

msgctxt "DT_Levels@e0@c1c9"
msgid "High Energy Physics"
msgstr "고에너지 물리학"

msgctxt "DT_Levels@e0@c215"
msgid "Unlocks the <Bold>Particle Accelerator</> which lets you convert radioactive materials into <Bold>Antimatter</>."
msgstr "방사성 물질을 <Bold>반물질</>로 변환할 수 있는 <Bold>입자 가속기</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@c324"
msgid "<Bold>Antimatter</> is generated inside the <Bold>Particle Accelerator</>. This is formed from a <Bold>Control Centre</> and a ring of <Bold>Conduit</> running through one or more <Bold>Towers</>.\r\n\r\nThe <Bold>larger</> the particle accelerator loop you build, the <Bold>faster</> you can generate antimatter - but the <Bold>more power</> is required."
msgstr "<Bold>반물질</>은 <Bold>입자 가속기</> 안에서 생성됩니다. 이는 <Bold>제어 센터</>와 하나 이상의 <Bold>타워</>를 통과하는 <Bold>도관</> 고리로 구성됩니다.\n\n입자 가속기 루프를 <Bold>크게</> 건설할수록 반물질을 <Bold>더 빠르게</> 생성할 수 있지만 <Bold>더 많은 전력</>이 필요합니다."

msgctxt "DT_Levels@e0@c4f5"
msgid "Antimatter Power Generation"
msgstr "반물질 전력 생산"

msgctxt "DT_Levels@e0@c549"
msgid "Unlocks the <Bold>Antimatter Reactor</> which lets you generate huge amounts of <Bold>power</> from <Bold>antimatter</>."
msgstr "<Bold>반물질</>로부터 막대한 양의 <Bold>전력</>을 생성할 수 있는 <Bold>반물질 원자로</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@c640"
msgid "You now have access to the <Bold>Antimatter Reactor</> which can consume <Bold>antimatter</> to produce <Bold>vast quantities of energy</>.\r\n\r\nThis process does produce a large amount of <Bold>nuclear waste</> however which you will need to remove and process to prevent radioactive build-ups."
msgstr "이제 <Bold>반물질</>을 소비해 <Bold>막대한 양의 에너지</>를 생산할 수 있는 <Bold>반물질 원자로</>에 접근할 수 있습니다.\n\n그러나 이 공정은 대량의 <Bold>핵 폐기물</>을 생산하므로, 방사능 축적을 방지하기 위해 제거하고 처리해야 합니다."

msgctxt "DT_Levels@e0@c7fe"
msgid "Nuclear Waste Processing"
msgstr "핵 폐기물 처리"

msgctxt "DT_Levels@e0@c84f"
msgid "Unlocks processes required for converting <Bold>nuclear waste</> into <Bold>usable materials and items</>."
msgstr "<Bold>핵 폐기물</>을 <Bold>사용 가능한 재료와 아이템</>으로 변환하는 데 필요한 공정을 잠금 해제합니다."

msgctxt "DT_Levels@e0@c93c"
msgid "You have now unlocked the ability to process <Bold>Nuclear Waste</> byproducts into <Bold>usable items and materials</>."
msgstr "이제 <Bold>핵 폐기물</> 부산물을 <Bold>사용 가능한 아이템과 재료</>로 처리하는 능력이 잠금 해제되었습니다."

msgctxt "DT_Levels@e0@ca58"
msgid "Enhanced Military Starships"
msgstr "강화 군용 우주선"

msgctxt "DT_Levels@e0@caac"
msgid "Unlocks additional <Bold>military-grade</> starship parts and ship classes."
msgstr "추가 <Bold>군용</> 우주선 부품과 함급을 잠금 해제합니다."

msgctxt "DT_Levels@e0@cb7e"
msgid "You have unlocked a higher tier of <Bold>military starship</> construction, including additional starship parts and more advanced ship classes ready to be built from the <Bold>Shipyard</>."
msgstr "<Bold>조선소</>에서 건조할 수 있는 추가 우주선 부품과 더 고급의 함급을 포함한 <Bold>군용 우주선</> 건조의 더 높은 등급을 잠금 해제했습니다."

msgctxt "DT_Levels@e0@ccb4"
msgid "Radiation Protection"
msgstr "방사능 방호"

msgctxt "DT_Levels@e0@cd01"
msgid "Unlocks technologies for <Bold>protecting</> your Drone and Station Modules from the harmful effects of <Bold>radiation</>."
msgstr "<Bold>방사능</>의 유해 영향으로부터 드론과 스테이션 모듈을 <Bold>보호</>하는 기술을 잠금 해제합니다."

msgctxt "DT_Levels@e0@cdef"
msgid "Various technologies for <Bold>protecting</> your Drone and Station Modules from the harmful effects of <Bold>radiation</> have been unlocked.\r\n\r\n<Bold>Radiation Filters</> will protect your Drone from external <Bold>radiation damage</>, but only last for a short time before needing to be <Bold>replaced</>."
msgstr "<Bold>방사능</>의 유해 영향으로부터 드론과 스테이션 모듈을 <Bold>보호</>하는 다양한 기술이 잠금 해제되었습니다.\n\n<Bold>방사선 필터</>는 외부 <Bold>방사능 피해</>로부터 드론을 보호하지만, 짧은 시간만 지속되며 <Bold>교체</>가 필요합니다."

msgctxt "DT_Levels@e0@cfc2"
msgid "Unstable Element Containment"
msgstr "불안정 원소 격납"

msgctxt "DT_Levels@e0@d017"
msgid "Unlocks the ability to safely store and contain unstable or radioactive elements."
msgstr "불안정하거나 방사성인 원소를 안전하게 저장하고 격납할 수 있는 능력을 잠금 해제합니다."

msgctxt "DT_Levels@e0@d0df"
msgid "You have now unlocked the <Bold>Containment Chamber</>.\r\n\r\nAs long as it is <Bold>powered</>, this device can be used to safely store <Bold>Antimatter and radioactive elements</> without losing containment or damaging nearby machines."
msgstr "이제 <Bold>격납 체임버</>가 잠금 해제되었습니다.\n\n<Bold>전원이 공급되는</> 한, 이 장치는 격납을 잃거나 인근 기계를 손상시키지 않고 <Bold>반물질과 방사성 원소</>를 안전하게 저장하는 데 사용할 수 있습니다."

msgctxt "DT_Levels@e0@d25f"
msgid "Force-Field Technology"
msgstr "역장 기술"

msgctxt "DT_Levels@e0@d2ae"
msgid "Unlocks <Bold>force-field-based technologies</> which can be used to protect your station from external threats."
msgstr "외부 위협으로부터 스테이션을 보호하는 데 사용할 수 있는 <Bold>역장 기반 기술</>을 잠금 해제합니다."

msgctxt "DT_Levels@e0@d39d"
msgid "You have now unlocked <Bold>Force-Field Generators</>, which can be used to <Bold>protect your stations</> from all forms of damage - including <Bold>firestorms and electrical storms</>."
msgstr "이제 <Bold>역장 발생기</>가 잠금 해제되었습니다. <Bold>화염 폭풍과 전기 폭풍</>을 포함한 모든 형태의 피해로부터 <Bold>스테이션을 보호</>하는 데 사용할 수 있습니다."

msgctxt "DT_Levels@e0@d4c1"
msgid "Operation: Junkyard"
msgstr "작전: 고철장"

msgctxt "DT_Levels@e0@d559"
msgid "If we are to survive in this system, its imperative that the <Bold>robot production facility</> our forces discovered in orbit around <Bold>Cerberus</> is <Bold>neutralized</>.\r\n\r\nHowever, this complex is heavily guarded by <Bold>hostile robot patrols</> left over from an ancient war..."
msgstr "이 성계에서 살아남으려면, 우리 부대가 <Bold>케르베로스</> 궤도에서 발견한 <Bold>로봇 생산 시설</>을 <Bold>중립화</>하는 것이 필수적입니다.\n\n그러나 이 복합 시설은 고대 전쟁에서 남은 <Bold>적대 로봇 순찰대</>에 의해 강력히 방어되고 있습니다..."

msgctxt "DT_Levels@e0@d6ac"
msgid "Its time to take the gloves off, Station Commander, and perform a <Bold>surgical strike</> with a task-force of powerful <Bold>military capital ships</> - we think the following will be sufficient to get the job done:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "장갑을 벗을 때입니다, 스테이션 사령관님. 강력한 <Bold>군용 주력함</> 기동대로 <Bold>정밀 타격</>을 수행해야 합니다 — 다음이 임무를 완수하기에 충분할 것이라 봅니다:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@d7dd"
msgid "Mission Complete, Station Commander: <Bold>Target Destroyed.</>\r\n\r\nBecause of your success in this mission, we've decided to promote you to the rank of <Bold>Station Captain!</>"
msgstr "임무 완료, 스테이션 사령관님: <Bold>목표 파괴.</>\n\n이 임무에서의 성공으로 인해 <Bold>스테이션 대위</> 계급으로 승진시키기로 결정했습니다!"

msgctxt "DT_Levels@e0@d8c2"
msgid "With the main source of hostiles neutralized in this system - and with the technologies you have unlocked so far - its time to move onto the <Bold>next phase</> of our operations in the TAU system: \r\n\r\nConstructing our <Bold>Intergalactic Arkship</> and escaping this galaxy before <Bold>The Void</> catches up with us again."
msgstr "이 성계에서 적대 세력의 주요 출처가 중립화되었고, 지금까지 잠금 해제한 기술로, 이제 TAU 성계에서 운영의 <Bold>다음 단계</>로 넘어갈 시간입니다:\n\n<Bold>은하 간 방주선</>을 건조하고 <Bold>공허</>가 우리를 다시 따라잡기 전에 이 은하를 탈출하는 것."

msgctxt "DT_Levels@e0@dadb"
msgid "Operation: Junkyard"
msgstr "작전: 고철장"

msgctxt "DT_Levels@e0@db22"
msgid "After <Bold>losing contact</> with our long-range scouting mission, we discovered that an ancient <Bold>automated robot production facility</> is still operational near the <Bold>Lava Planet Cerberus</>.\r\n\r\nThis is likely the source of most of the <Bold>hostile robots</> we've encountered in the system, so our next course of action must be to mount a <Bold>military operation</> and eliminate it."
msgstr "우리의 장거리 정찰 임무와 <Bold>통신을 잃은</> 후, 고대 <Bold>자동화 로봇 생산 시설</>이 여전히 <Bold>용암 행성 케르베로스</> 인근에서 작동 중임을 발견했습니다.\n\n이는 성계에서 마주친 대부분의 <Bold>적대 로봇</>의 출처일 가능성이 높으므로, 다음 행동 방침은 <Bold>군사 작전</>을 시행하여 이를 제거하는 것입니다."

msgctxt "DT_Levels@e0@dd24"
msgid "Quantum Physics"
msgstr "양자 물리학"

msgctxt "DT_Levels@e0@dd6c"
msgid "Unlocks <Bold>Quantum-based technologies</>"
msgstr "<Bold>양자 기반 기술</>을 잠금 해제합니다"

msgctxt "DT_Levels@e0@de2e"
msgid "We have made a significant scientific breakthrough in <Bold>Quantum Physics</>, and unlocked several <Bold>new parts and materials</> that can be used in further technologies."
msgstr "<Bold>양자 물리학</>에서 중요한 과학적 돌파구를 마련했고, 추가 기술에 사용할 수 있는 여러 <Bold>새 부품과 재료</>를 잠금 해제했습니다."

msgctxt "DT_Levels@e0@df5b"
msgid "Advanced AI Robotics"
msgstr "고급 AI 로봇공학"

msgctxt "DT_Levels@e0@dfa8"
msgid "Unlocks the <Bold>Servitor Station</> which deploys a programmable <Bold>robotic AI helper</>."
msgstr "프로그래밍 가능한 <Bold>로봇 AI 보조</>를 배치하는 <Bold>서비터 스테이션</>을 잠금 해제합니다."

msgctxt "DT_Levels@e0@e07d"
msgid "The <Bold>Servitor Station</> deploys a helpful <Bold>AI-powered robot</> that can be set to automatically perform tasks around your station such as <Bold>repairing damaged modules</>, aligning <Bold>solar panels</> and <Bold>collecting resources</> when <Bold>linked</> to a suitable destination module."
msgstr "<Bold>서비터 스테이션</>은 유용한 <Bold>AI 로봇</>을 배치하며, 적절한 대상 모듈에 <Bold>연결</>하면 <Bold>손상된 모듈 수리</>, <Bold>태양광 패널</> 정렬, <Bold>자원 수집</> 같은 작업을 스테이션 주변에서 자동으로 수행하도록 설정할 수 있습니다."

msgctxt "DT_Levels@e0@e1e1"
msgid "A particularly useful function for the Servitor is to automate the collection of <Bold>Exotic Matter</> from the <Bold>Junkyard Zone</>."
msgstr "서비터의 특히 유용한 기능은 <Bold>고철장 구역</>에서 <Bold>이그조틱 물질</> 수집을 자동화하는 것입니다."

msgctxt "DT_Levels@e0@e2e3"
msgid "Advanced Portals"
msgstr "고급 포털"

msgctxt "DT_Levels@e0@e32c"
msgid "Unlocks the <Bold>Mk 2 Wormhole</> which can transport more items, gases and liquids at a <Bold>faster rate</>."
msgstr "더 많은 아이템, 기체, 액체를 <Bold>더 빠른 속도</>로 운송할 수 있는 <Bold>Mk 2 웜홀</>을 잠금 해제합니다."

msgctxt "DT_Levels@e0@e430"
msgid "<Bold>Mk 2 Wormholes</> have now been unlocked. \r\n\r\nThese can transport more items, gases and liquids between remote parts of your stations at a faster rate."
msgstr "<Bold>Mk 2 웜홀</>이 잠금 해제되었습니다.\n\n스테이션의 원격 부분 간 더 많은 아이템, 기체, 액체를 더 빠른 속도로 운송할 수 있습니다."

msgctxt "DT_Levels@e0@e542"
msgid "Quantum Storage"
msgstr "양자 저장소"

msgctxt "DT_Levels@e0@e58a"
msgid "Unlocks the <Bold>Quantum Storage</> device which lets you feed in items and parts and then <Bold>access them from anywhere</> via your <Bold>Drone's inventory</>."
msgstr "아이템과 부품을 투입한 다음 <Bold>드론 인벤토리</>를 통해 <Bold>어디서든 접근</>할 수 있는 <Bold>양자 저장</> 장치를 잠금 해제합니다."

msgctxt "DT_Levels@e0@e6a4"
msgid "<Bold>Quantum Storage</> units have now been unlocked. \r\n\r\nFeed items and materials into this device and <Bold>access them anywhere</> from your <Bold>Drone's inventory</>."
msgstr "<Bold>양자 저장</> 유닛이 잠금 해제되었습니다.\n\n아이템과 재료를 이 장치에 투입하고 <Bold>드론 인벤토리</>에서 <Bold>어디서든 접근</>하세요."

msgctxt "DT_Levels@e0@e7f2"
msgid "Centrifuge Technology"
msgstr "원심분리 기술"

msgctxt "DT_Levels@e0@e840"
msgid "Unlocks the <Bold>Centrifuge</> which can be used to enrich <Bold>waste products</> and convert them into <Bold>useable materials</>."
msgstr "<Bold>폐기물</>을 농축하여 <Bold>사용 가능한 재료</>로 변환하는 데 사용할 수 있는 <Bold>원심분리기</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@e944"
msgid "The <Bold>Centrifuge</> has now been unlocked. \r\n\r\nThis device can be used to <Bold>enrich waste products</> and convert them into <Bold>usable materials</>."
msgstr "<Bold>원심분리기</>가 잠금 해제되었습니다.\n\n이 장치는 <Bold>폐기물을 농축</>하여 <Bold>사용 가능한 재료</>로 변환하는 데 사용할 수 있습니다."

msgctxt "DT_Levels@e0@ea6a"
msgid "Arkship Terminal"
msgstr "방주선 터미널"

msgctxt "DT_Levels@e0@eafe"
msgid "<Bold>The Arkship</> will be our race's <Bold>greatest achievement</> - and our salvation - but its construction will take everything we have."
msgstr "<Bold>방주선</>은 우리 종족의 <Bold>최고의 업적</> — 그리고 우리의 구원 — 이 될 것이지만, 그 건조에는 우리가 가진 모든 것을 쏟아부어야 할 것입니다."

msgctxt "DT_Levels@e0@ebc0"
msgid "The first step will be constructing an <Bold>Arkship Terminal</>, which will serve as a nexus to channel items, parts and materials into the project. This is now available to construct from the <Bold>Build menu</>."
msgstr "첫 단계는 <Bold>방주선 터미널</>을 건조하는 것입니다. 이는 아이템, 부품, 재료를 프로젝트로 채널링하는 중심부 역할을 합니다. 이제 <Bold>건설 메뉴</>에서 건설할 수 있습니다."

msgctxt "DT_Levels@e0@ecca"
msgid "We've also picked up some <Bold>interesting readings</> from the orbit of the gas giant <Bold>Scylla</> - we recommend dispatching an <Bold>exploration mission</> there immediately with the following ships:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "또한 가스 거성 <Bold>스킬라</> 궤도에서 <Bold>흥미로운 신호</>를 포착했습니다 — 다음 함선들로 즉시 <Bold>탐사 임무</>를 그곳에 파견할 것을 권장합니다:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@edf4"
msgid "Well done Station Commander, the Arkship Terminal is now <Bold>fully operational</>.\r\n\r\nWhen you're ready, you can start feeding in the required items, parts and materials and take us to the <Bold>next stage</> of operation."
msgstr "잘하셨습니다 스테이션 사령관님, 방주선 터미널이 이제 <Bold>완전 가동</>됩니다.\n\n준비되시면 필요한 아이템, 부품, 재료를 투입하기 시작하여 운영의 <Bold>다음 단계</>로 데려가실 수 있습니다."

msgctxt "DT_Levels@e0@ef08"
msgid "Our <Bold>exploration mission</> to the gas giant <Bold>Scylla</> has also discovered an extremely <Bold>mineral-rich moon</> orbiting the planet - <Bold>Helion</> - and this location has been added to the System Map ready for <Bold>immediate expansion</>."
msgstr "가스 거성 <Bold>스킬라</>로의 <Bold>탐사 임무</>는 행성을 공전하는 매우 <Bold>광물이 풍부한 위성</> — <Bold>헬리온</> — 도 발견했고, 이 장소가 <Bold>즉각 확장</>을 위해 시스템 지도에 추가되었습니다."

msgctxt "DT_Levels@e0@f0c2"
msgid "Building The Arkship"
msgstr "방주선 건조"

msgctxt "DT_Levels@e0@f10a"
msgid "After neutralising an <Bold>ancient robot production facility</> in orbit around the <Bold>Lava Planet Cerberus</> - and developing many new manufacturing technologies - we believe we are finally ready to start production on our <Bold>Intergalactic Arkship</> and escape this doomed galaxy forever.\r\n\r\nThis is not going to be easy, however, and <Bold>The Void</> has <Bold>accelerated its expansion</> - so we may not have as much time as we hoped..."
msgstr "<Bold>용암 행성 케르베로스</> 궤도의 <Bold>고대 로봇 생산 시설</>을 중립화하고 — 많은 새 제조 기술을 개발한 후 — 마침내 <Bold>은하 간 방주선</> 생산을 시작하고 이 운명 지어진 은하를 영원히 탈출할 준비가 됐다고 봅니다.\n\n그러나 이는 쉽지 않을 것이며, <Bold>공허</>가 <Bold>팽창을 가속화</>하고 있어 — 바랐던 만큼의 시간이 없을 수 있습니다..."

msgctxt "DT_Levels@e0@f308"
msgid "The Arkship"
msgstr "방주선"

msgctxt "DT_Levels@e0@f37d"
msgid "Armoured Materials"
msgstr "장갑 재료"

msgctxt "DT_Levels@e0@f3c8"
msgid "Researches <Bold>Tungten Carbide</> and related materials for extreme damage resistance."
msgstr "극한의 피해 저항을 위한 <Bold>탄화 텅스텐</>과 관련 재료를 연구합니다."

msgctxt "DT_Levels@e0@f4ab"
msgid "We've completed research into the material <Bold>Tungsten Carbide</>.\r\n\r\nThis very dense, tough material can be used in extreme environments and high pressure systems."
msgstr "<Bold>탄화 텅스텐</> 재료에 대한 연구를 완료했습니다.\n\n이 매우 밀도 높고 강한 재료는 극한 환경과 고압 시스템에 사용할 수 있습니다."

msgctxt "DT_Levels@e0@f5c5"
msgid "Component Factory"
msgstr "부품 공장"

msgctxt "DT_Levels@e0@f60f"
msgid "Unlocks the <Bold>Component Factory</> module, which can produce large <Bold>Starship</> and <Bold>Arkship components</>."
msgstr "큰 <Bold>우주선</>과 <Bold>방주선 부품</>을 생산할 수 있는 <Bold>부품 공장</> 모듈을 잠금 해제합니다."

msgctxt "DT_Levels@e0@f71f"
msgid "The <Bold>Component Factory</> has been unlocked.\r\n\r\nThis module is used to produce larger <Bold>Starship</> and <Bold>Arkship components</> which will require a tug to install into their destination."
msgstr "<Bold>부품 공장</>이 잠금 해제되었습니다.\n\n이 모듈은 큰 <Bold>우주선</>과 <Bold>방주선 부품</>을 생산하는 데 사용되며, 목적지에 설치하려면 예인선이 필요합니다."

msgctxt "DT_Levels@e0@f860"
msgid "Large Ship Construction"
msgstr "대형 함선 건조"

msgctxt "DT_Levels@e0@f8b0"
msgid "Unlocks the <Bold>Large Shipyard</>, which can construct the largest classes of ships."
msgstr "가장 큰 함급을 건조할 수 있는 <Bold>대형 조선소</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@f989"
msgid "The <Bold>Large Shipyard</> has been unlocked.\r\n\r\nThis can construct the very largest classes of starship, which will require a <Bold>large tug</> to move around your station."
msgstr "<Bold>대형 조선소</>가 잠금 해제되었습니다.\n\n가장 큰 함급의 우주선을 건조할 수 있으며, 스테이션 주변에서 이동시키려면 <Bold>대형 예인선</>이 필요합니다."

msgctxt "DT_Levels@e0@facf"
msgid "Large Starship Transportation"
msgstr "대형 우주선 운송"

msgctxt "DT_Levels@e0@fb25"
msgid "Unlocks the <Bold>Large Tug Bay</> and <Bold>Large Ship Tugs</> which can transport the largest ships around your station."
msgstr "스테이션 주변에서 가장 큰 함선을 운송할 수 있는 <Bold>대형 예인선 도크</>와 <Bold>대형 함선 예인선</>을 잠금 해제합니다."

msgctxt "DT_Levels@e0@fc16"
msgid "You have unlocked the <Bold>Large Tug Bay</> and <Bold>Large Ship Tugs</> which can be used to transport even the largest ships around your station."
msgstr "스테이션 주변에서 가장 큰 함선까지도 운송하는 데 사용할 수 있는 <Bold>대형 예인선 도크</>와 <Bold>대형 함선 예인선</>이 잠금 해제되었습니다."

msgctxt "DT_Levels@e0@fd1d"
msgid "Exoplanet Ops"
msgstr "외계행성 운영"

msgctxt "DT_Levels@e0@fd63"
msgid "Unlocks the <Bold>Exoplanet Ops Centre</> which can deploy <Bold>Planetary Lifters</> to fetch resources from the surface of compatible planets."
msgstr "호환 행성 표면에서 자원을 가져오는 <Bold>행성 리프터</>를 배치할 수 있는 <Bold>외계행성 운영 센터</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@fe6a"
msgid "You have now unlocked the <Bold>Exoplanet Ops Centre</>.\r\n\r\nThis module can deploy multiple <Bold>Planetary Lifters</> which can be set to fetch resources from the surface of compatible planets."
msgstr "이제 <Bold>외계행성 운영 센터</>가 잠금 해제되었습니다.\n\n이 모듈은 호환 행성 표면에서 자원을 가져오도록 설정할 수 있는 여러 <Bold>행성 리프터</>를 배치할 수 있습니다."

msgctxt "DT_Levels@e0@ffaa"
msgid "Advanced Fluid Transport"
msgstr "고급 유체 운송"

msgctxt "DT_Levels@e0@fffb"
msgid "Unlocks <Bold>Mark 2 Pipes</> and an <Bold>increased gas/fluid output rate</> to speed up how fast you can transport gases and fluids around your station."
msgstr "스테이션 주변에서 기체와 유체를 운송하는 속도를 높이는 <Bold>Mark 2 파이프</>와 <Bold>증가된 기체/유체 출력 속도</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@10117"
msgid "You have unlocked <Bold>Mark 2 Pipes</> and an <Bold>increased gas/fluid output rate</>.\r\n\r\nTogether these will vastly speed up how fast you can transport gases and fluids around your station."
msgstr "<Bold>Mark 2 파이프</>와 <Bold>증가된 기체/유체 출력 속도</>를 잠금 해제했습니다.\n\n이 둘은 함께 스테이션 주변에서 기체와 유체를 운송하는 속도를 크게 높입니다."

msgctxt "DT_Levels@e0@10285"
msgid "Antimatter Fuelling"
msgstr "반물질 연료 주입"

msgctxt "DT_Levels@e0@102d1"
msgid "Unlocks the <Bold>Mk 3 Fuel Depot</> which has a faster fuel transfer rate and can supply <Bold>Antimatter</> to larger ships, as well as the Crusader Auxilliary, a Capital-class resupply ship."
msgstr "더 빠른 연료 전달 속도를 가지고 더 큰 함선에 <Bold>반물질</>을 공급할 수 있는 <Bold>Mk 3 연료 저장고</>와 주력함급 재보급 함선인 크루세이더 보조함을 잠금 해제합니다."

msgctxt "DT_Levels@e0@1042d"
msgid "The <Bold>Mk 3 Fuel Depot</> has now been unlocked.\r\n\r\nThis module has a <Bold>faster fuel transfer rate</> and can both store and supply <Bold>Antimatter</> to the largest starships.\r\n\r\nYou can now also construct the Crusader Auxilliary, a Capital-class resupply ship which can refuel both fusion and antimatter-based starships."
msgstr "<Bold>Mk 3 연료 저장고</>가 잠금 해제되었습니다.\n\n이 모듈은 <Bold>더 빠른 연료 전달 속도</>를 가지고 가장 큰 우주선에 <Bold>반물질</>을 저장하고 공급할 수 있습니다.\n\n또한 융합과 반물질 기반 우주선 모두를 재급유할 수 있는 주력함급 재보급 함선인 크루세이더 보조함을 건조할 수 있습니다."

msgctxt "DT_Levels@e0@10608"
msgid "Quantum Rift Extraction"
msgstr "양자 균열 추출"

msgctxt "DT_Levels@e0@10658"
msgid "Unlocks the <Bold>Quantum Extractor</> which can extract Exotic Matter directly from a Quantum Rift"
msgstr "양자 균열에서 이그조틱 물질을 직접 추출할 수 있는 <Bold>양자 추출기</>를 잠금 해제합니다"

msgctxt "DT_Levels@e0@10732"
msgid "The <Bold>Quantum Extractor</> has now been unlocked.\r\n\r\nConstruct this advanced device onto <Bold>Quantum Rifts</> you can find in locations like the <Bold>Junkyard</> to automate large-scale extraction of <Bold>Exotic Matter</>."
msgstr "<Bold>양자 추출기</>가 잠금 해제되었습니다.\n\n<Bold>고철장</> 같은 장소에서 발견할 수 있는 <Bold>양자 균열</>에 이 고급 장치를 건설하여 <Bold>이그조틱 물질</>의 대규모 추출을 자동화하세요."

msgctxt "DT_Levels@e0@108a9"
msgid "Arkship Dock"
msgstr "방주선 도크"

msgctxt "DT_Levels@e0@10960"
msgid "Commander, all of our <Bold>deep-space scanning</> stations have just <Bold>gone dark</>, and we are completely blind to what is happening in this sector of space..."
msgstr "사령관님, 우리의 모든 <Bold>심우주 스캔</> 스테이션이 방금 <Bold>무응답</>이 되었고, 이 우주 구역에서 무슨 일이 일어나는지 완전히 알 수 없게 되었습니다..."

msgctxt "DT_Levels@e0@10a39"
msgid "We can patch this gap with a network of our most powerful <Bold>science and scanning ships</>, along with an appropriate escort of military and resupply ships:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "가장 강력한 <Bold>과학 및 스캔 함선</> 네트워크와 함께 적절한 군용 및 재보급 함선 호위로 이 공백을 메울 수 있습니다:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@10b20"
msgid "While this mission is underway, it's also <Bold>vital</> that you continue construction of our Intergalactic Arkship Project.\r\n\r\nThe next phase of the project will be building the <Bold>Arkship Dock</>, ready to begin construction of the Arkship itself."
msgstr "이 임무가 진행되는 동안, 우리의 은하 간 방주선 프로젝트 건조를 계속하는 것도 <Bold>필수적</>입니다.\n\n프로젝트의 다음 단계는 방주선 자체의 건조를 시작할 준비가 된 <Bold>방주선 도크</>를 짓는 것입니다."

msgctxt "DT_Levels@e0@10c65"
msgid "<Bold>Bad news</>, Commander...\r\n\r\nWe've just heard back from the fleet we dispatched to the edge of the system, and it's official: <Bold>The Void has arrived...</>"
msgstr "<Bold>나쁜 소식</>입니다, 사령관님...\n\n성계 끝자락으로 파견한 함대로부터 방금 보고를 받았고, 이는 공식입니다: <Bold>공허가 도달했습니다...</>"

msgctxt "DT_Levels@e0@10d3d"
msgid "The Void's last <Bold>Expansion Phase</> has halted at the edge of this system, but another Expansion could occur at any time... we need to get the Arkship completed as soon as we can, Commander!"
msgstr "공허의 마지막 <Bold>팽창 단계</>는 이 성계 끝자락에서 멈췄지만, 또 다른 팽창이 언제든 일어날 수 있습니다... 가능한 한 빨리 방주선을 완성해야 합니다, 사령관님!"

msgctxt "DT_Levels@e0@10e34"
msgid "Analysis has confirmed that a station could survive on the edge of The Void's event horizon, and could provide invaluable insight into the inner workings of this mysterious cosmic entity...\r\n\r\nThis location has been added to your <Bold>System Map</>."
msgstr "분석 결과 스테이션이 공허의 사건 지평선 가장자리에서 생존할 수 있고, 이 신비로운 우주 존재의 내부 작동에 대한 귀중한 통찰을 제공할 수 있다는 것이 확인되었습니다...\n\n이 장소가 <Bold>시스템 지도</>에 추가되었습니다."

msgctxt "DT_Levels@e0@11024"
msgid "Space Elevator"
msgstr "우주 엘리베이터"

msgctxt "DT_Levels@e0@1106b"
msgid "Unlocks the <Bold>Space Elevator</> - a massive structure that can lift valuable resources from the surface of a planet."
msgstr "행성 표면에서 귀중한 자원을 들어 올릴 수 있는 거대한 구조물인 <Bold>우주 엘리베이터</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@11162"
msgid "You have unlocked the <Bold>Space Elevator</>.\r\n\r\nThis massive orbital structure is capable of lifting valuable items, materials and parts from the surface of a planet, ready to be used in your station."
msgstr "<Bold>우주 엘리베이터</>를 잠금 해제했습니다.\n\n이 거대한 궤도 구조물은 행성 표면에서 귀중한 아이템, 재료, 부품을 들어 올려 스테이션에서 사용할 수 있게 합니다."

msgctxt "DT_Levels@e0@112ad"
msgid "Quantum Destabilization"
msgstr "양자 안정화 파괴"

msgctxt "DT_Levels@e0@112fd"
msgid "Unlocks materials, items and parts related to <Bold>Quantum Destabilization</> - a highly experimental technology which has the power to <Bold>disrupt cosmic phenomena</> such as black holes."
msgstr "블랙홀 같은 <Bold>우주 현상을 교란</>하는 힘을 가진 고도로 실험적인 기술인 <Bold>양자 안정화 파괴</>와 관련된 재료, 아이템, 부품을 잠금 해제합니다."

msgctxt "DT_Levels@e0@11447"
msgid "We have completed research into the field of Quantum Destabilization.\r\n\r\nAccording to our scientists, this highly experimental technology has the power to disrupt quantum entities - such as singularities - and may help us in our fight against The Void."
msgstr "양자 안정화 파괴 분야의 연구를 완료했습니다.\n\n우리 과학자들에 따르면, 이 고도로 실험적인 기술은 특이점 같은 양자 존재를 교란할 힘을 가지고 있어 공허와의 싸움에서 우리에게 도움이 될 수 있습니다."

msgctxt "DT_Levels@e0@115bf"
msgid "Battlecruisers"
msgstr "전투순양함"

msgctxt "DT_Levels@e0@11606"
msgid "Unlocks the <Bold>Battlecruiser class</> of starship - a massive capital-class ship that can mount the heaviest experimental weaponry."
msgstr "가장 무거운 실험 무기를 장착할 수 있는 거대한 주력함급 함선인 우주선의 <Bold>전투순양함급</>을 잠금 해제합니다."

msgctxt "DT_Levels@e0@1170b"
msgid "You have unlocked the Battlecruiser class of starship.\r\n\r\nThis massive capital-class ship can mount the heaviest experimental weaponry and will be invaluable in our fight against The Void."
msgstr "우주선의 전투순양함급을 잠금 해제했습니다.\n\n이 거대한 주력함급 함선은 가장 무거운 실험 무기를 장착할 수 있고 공허와의 싸움에서 매우 귀중할 것입니다."

msgctxt "DT_Levels@e0@11868"
msgid "Magnetic Accelerator"
msgstr "자기 가속기"

msgctxt "DT_Levels@e0@118b5"
msgid "Unlocks the <Bold>Magnetic Accelerator</> which can target and destroy <Bold>Void Anomalies</> you may encounter at The Void's event horizon location."
msgstr "공허의 사건 지평선 장소에서 마주칠 수 있는 <Bold>공허 이상 현상</>을 표적으로 하여 파괴할 수 있는 <Bold>자기 가속기</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@119ca"
msgid "You have unlocked the <Bold>Magnetic Accelerator</>.\r\n\r\nThis massive cannon can fire <Bold>Quantum Implosion Ammo</> at the <Bold>Void Anomalies</> you may encounter at The Void's <Bold>Event Horizon location</>.\r\n\r\nWhen destroyed, these anomalies may leave behind the rare and valuable material <Bold>Neutronium</>."
msgstr "<Bold>자기 가속기</>를 잠금 해제했습니다.\n\n이 거대한 대포는 공허의 <Bold>사건 지평선 장소</>에서 마주칠 수 있는 <Bold>공허 이상 현상</>에 <Bold>양자 내파 탄약</>을 발사할 수 있습니다.\n\n파괴되면 이 이상 현상들은 희귀하고 귀중한 재료인 <Bold>중성자물질</>을 남길 수 있습니다."

msgctxt "DT_Levels@e0@11ba8"
msgid "Neutronium Processing"
msgstr "중성자물질 가공"

msgctxt "DT_Levels@e0@11bf6"
msgid "Unlocks the ability to process <Bold>Neutronium</> into powerful <Bold>hyperdrive fuel</> that can be used in intergalactic star-drives."
msgstr "은하 간 항성 추진 장치에 사용할 수 있는 강력한 <Bold>하이퍼드라이브 연료</>로 <Bold>중성자물질</>을 처리하는 능력을 잠금 해제합니다."

msgctxt "DT_Levels@e0@11cf9"
msgid "You have unlocked the ability to process <Bold>Neutronium</>.\r\n\r\nThis rare and valuable stellar substance is found in the core of stars and black holes, and can be refined into <Bold>Hyperdrive Fuel</> which can power intergalactic star-drives."
msgstr "<Bold>중성자물질</> 처리 능력을 잠금 해제했습니다.\n\n이 희귀하고 귀중한 항성 물질은 항성과 블랙홀 핵에서 발견되며, 은하 간 항성 추진 장치를 구동할 수 있는 <Bold>하이퍼드라이브 연료</>로 정제할 수 있습니다."

msgctxt "DT_Levels@e0@11e87"
msgid "Antimatter Lazer"
msgstr "반물질 레이저"

msgctxt "DT_Levels@e0@11ed0"
msgid "Unlocks the <Bold>Antimatter Lazer</> which is a powerful beam weapon that can be crafted from the <Bold>Equipment Station</>."
msgstr "<Bold>장비 정거장</>에서 제작할 수 있는 강력한 빔 무기인 <Bold>반물질 레이저</>를 잠금 해제합니다."

msgctxt "DT_Levels@e0@11fc9"
msgid "You have now unlocked the <Bold>Antimatter Lazer</>.\r\n\r\nThis is an extremely powerful beam weapon that can be crafted from the <Bold>Equipment Station</> and can be used to defend yourself from even the most powerful enemies."
msgstr "이제 <Bold>반물질 레이저</>가 잠금 해제되었습니다.\n\n이는 <Bold>장비 정거장</>에서 제작할 수 있는 극도로 강력한 빔 무기로, 가장 강력한 적으로부터도 스스로를 방어하는 데 사용할 수 있습니다."

msgctxt "DT_Levels@e0@12131"
msgid "Complete The Arkship"
msgstr "방주선 완성"

msgctxt "DT_Levels@e0@121cd"
msgid "With our recent advancements in <Bold>Quantum Destablization</> technology, it may actually be possible to temporarily delay The Void's next expansion phase - giving us enough time to complete the <Bold>Arkship</> and escape this galaxy..."
msgstr "최근 <Bold>양자 안정화 파괴</> 기술의 발전으로, 실제로 공허의 다음 팽창 단계를 일시적으로 지연시켜 <Bold>방주선</>을 완성하고 이 은하를 탈출할 시간을 충분히 벌 수 있을지도 모릅니다..."

msgctxt "DT_Levels@e0@122f0"
msgid "This will require a flotilla of our most <Bold>powerful battlecruisers</> - fitted with this devastating weapons technology - all working in unison:\r\n\r\n{REQUIRED_SHIPS}"
msgstr "이를 위해서는 가장 <Bold>강력한 전투순양함</> 함대가 — 이 파괴적인 무기 기술을 장착하고 — 일사불란하게 작동해야 합니다:\n\n{REQUIRED_SHIPS}"

msgctxt "DT_Levels@e0@123cc"
msgid "Now that the <Bold>Arkship Dock</> is complete, its time to put all of our efforts into building the <Bold>Arkship</> itself - use every means at your disposal Commander, <Bold>we may not have much time!</>"
msgstr "이제 <Bold>방주선 도크</>가 완성되었으니, 모든 노력을 <Bold>방주선</> 자체를 짓는 데 쏟을 시간입니다 — 사령관님, 가능한 모든 수단을 동원하세요. <Bold>시간이 많지 않을 수 있습니다!</>"

msgctxt "DT_Levels@e0@124e2"
msgid "<Bold>The Arkship is complete</>, Commander - truly an <Bold>amazing accomplishment!</>\r\n\r\nAll that remains is to power and fuel its <Bold>Intergalactic Stardrive</> - then we will be ready to <Bold>launch</>."
msgstr "<Bold>방주선이 완성되었습니다</>, 사령관님 — 정말 <Bold>놀라운 업적</>입니다!\n\n남은 것은 <Bold>은하 간 항성 추진 장치</>에 동력과 연료를 공급하는 것뿐입니다 — 그러면 <Bold>발진</> 준비가 됩니다."

msgctxt "DT_Levels@e0@12696"
msgid "Launch The Arkship"
msgstr "방주선 발진"

msgctxt "DT_Levels@e0@126e1"
msgid "Fuel and power the Intergalactic Arkship's Hyper-drive and escape the galaxy - and The Void - forever..."
msgstr "은하 간 방주선의 하이퍼드라이브에 연료와 동력을 공급하고 은하 — 그리고 공허 — 로부터 영원히 탈출하세요..."

msgctxt "DT_Levels@e0@127ad"
msgid "With the Arkship complete, we now have everything we need to escape the galaxy - and The Void - forever.\r\n\r\nAll that remains is to <Bold>power and fuel</> the Arkship's Intergalactic <Bold>Hyperdrive</> with neutronium-based fuel."
msgstr "방주선이 완성되어 이제 은하 — 그리고 공허 — 로부터 영원히 탈출하는 데 필요한 모든 것을 가지게 되었습니다.\n\n남은 것은 방주선의 은하 간 <Bold>하이퍼드라이브</>에 중성자물질 기반 연료로 <Bold>동력과 연료를 공급</>하는 것입니다."

msgctxt "DT_Levels@e0@128c7"
msgid "This experimental drive will require <Bold>massive amounts of power</> to initialise - so you will need to use all of your engineering abilities to accomplish this."
msgstr "이 실험적 추진 장치는 초기화에 <Bold>막대한 양의 전력</>이 필요합니다 — 따라서 이를 달성하려면 모든 공학 능력을 사용해야 합니다."

msgctxt "DT_Levels@e0@1299f"
msgid "Although our Battlecruisers have bought us some time, The Void could start its next <Bold>Expansion Phase</> at any time, so we recommend moving with <Bold>all haste</>, Commander..."
msgstr "우리 전투순양함이 시간을 벌어줬지만, 공허는 언제든 다음 <Bold>팽창 단계</>를 시작할 수 있으므로 <Bold>최대한 서두를</> 것을 권장합니다, 사령관님..."

msgctxt "DT_Levels@e0@12a9d"
msgid "Commander, the Arkship is fuelled, powered and ready to launch!"
msgstr "사령관님, 방주선의 연료 주입과 동력 공급이 완료되어 발진 준비가 끝났습니다!"

msgctxt "DT_Levels@e0@12b10"
msgid "But there's something you should know - we've been receiving communications from inside The Void, and its been confirmed: The people from our home system are still alive somehow - inside The Void - transcribed into a quantum state..."
msgstr "하지만 알아두셔야 할 것이 있습니다 — 우리는 공허 안에서 통신을 받아오고 있었고, 확인되었습니다: 우리 고향 성계의 사람들은 어떻게든 아직 살아있습니다 — 공허 안에서 — 양자 상태로 전사되어..."

msgctxt "DT_Levels@e0@12c2d"
msgid "According to them, The Void is NOT the great destroyer that we believed...\r\n\r\nInstead, it seems to be a vast machine created aeons ago to achieve Singularity for everyone in this galaxy... and its almost ready to activate..."
msgstr "그들에 따르면, 공허는 우리가 믿었던 위대한 파괴자가 아닙니다...\n\n그 대신, 이 은하의 모든 이를 위한 특이점을 달성하기 위해 영겁 전에 만들어진 거대한 기계로 보이며... 활성화 준비가 거의 됐습니다..."

msgctxt "DT_Levels@e0@12d41"
msgid "Its up to you now, Commander...\r\n\r\nDo we use the Arkship to join our lost kin inside The Void - or to escape this galaxy forever...?"
msgstr "이제 사령관님께 달렸습니다...\n\n방주선을 사용해 공허 안의 잃어버린 동족과 합류할까요 — 아니면 이 은하를 영원히 탈출할까요...?"

# ---------------------------------------------------------- DT_LoadingScreenTips
msgctxt "DT_LoadingScreenTips@e0@4d"
msgid "You can hide the upper level of your station by holding <ACTION=HideUpperLevel_B> or <ACTION=HideUpperLevel_B_Alt>"
msgstr "<ACTION=HideUpperLevel_B> 또는 <ACTION=HideUpperLevel_B_Alt>를 누르고 있으면 스테이션 상층부를 숨길 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@100"
msgid "You can collect multiple asteroids easily by holding <Bold>SHIFT</> and dragging with <Bold>LMB</>"
msgstr "<Bold>SHIFT</>를 누른 채 <Bold>좌클릭</>으로 드래그하면 여러 소행성을 한 번에 수집할 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@1a3"
msgid "Use the <Bold>Sensor View</> to locate nearby resources or enemies by holding <ACTION=Sensors> or <ACTION=Sensors ALT>"
msgstr "<ACTION=Sensors> 또는 <ACTION=Sensors ALT>를 누르고 있으면 <Bold>센서 뷰</>로 주변 자원이나 적을 찾을 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@25a"
msgid "Pressing <ACTION=Stop> while in <Bold>Connect Mode</> will clear all connections from the selected module"
msgstr "<Bold>연결 모드</>에서 <ACTION=Stop>을 누르면 선택한 모듈의 모든 연결이 해제됩니다"

msgctxt "DT_LoadingScreenTips@e0@304"
msgid "You can move items from a hovered object into your drone's inventory using <ACTION=Transfer_To_Drone>"
msgstr "<ACTION=Transfer_To_Drone>로 마우스를 올린 오브젝트의 아이템을 드론 인벤토리로 옮길 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@3aa"
msgid "You can teleport back to the Hub at any time by holding <ACTION=Home>"
msgstr "<ACTION=Home>을 누르고 있으면 언제든 허브로 순간이동 할 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@42f"
msgid "Use the <ACTION=Transfer_From_Drone> and <ACTION=Transfer_To_Drone> hotkeys to quickly move items to and from your drone and the currently hovered or selected object"
msgstr "<ACTION=Transfer_From_Drone>와 <ACTION=Transfer_To_Drone> 단축키로 드론과 마우스를 올리거나 선택한 오브젝트 사이에서 아이템을 빠르게 옮길 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@515"
msgid "The <Bold>Station Overview</> lets you quickly see how your station is performing (Hold <ACTION=Show Status>)"
msgstr "<Bold>스테이션 개요</>(<ACTION=Show Status> 길게 누름)에서 스테이션 상태를 빠르게 확인할 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@5c2"
msgid "Quickly switch hovered or selected modules on and off using <ACTION=Toggle Power>"
msgstr "<ACTION=Toggle Power>로 마우스를 올리거나 선택한 모듈의 전원을 빠르게 켜고 끌 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@654"
msgid "Add a waypoint using <ACTION=Create Waypoint> while in the <Bold>Map View</>"
msgstr "<Bold>지도 뷰</>에서 <ACTION=Create Waypoint>로 경유점을 추가할 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@6e1"
msgid "Rotate the currently placing module using <ACTION=Rotate Left>"
msgstr "<ACTION=Rotate Left>로 배치 중인 모듈을 회전시킬 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@75f"
msgid "The <Bold>Codex</> contains a lot of useful information including all previously seen tutorial videos"
msgstr "<Bold>코덱스</>에는 이전에 본 튜토리얼 영상을 포함한 다양한 유용한 정보가 담겨 있습니다"

msgctxt "DT_LoadingScreenTips@e0@804"
msgid "Most recipes can be <Bold>synthesized</> directly from your drone's inventory (hotkey: <ACTION=Inventory>)"
msgstr "대부분의 제작법은 드론 인벤토리(<ACTION=Inventory>)에서 직접 <Bold>합성</>할 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@8ae"
msgid "You can create a custom task by clicking the '+' button on the main toolbar"
msgstr "메인 툴바의 '+' 버튼을 눌러 사용자 지정 작업을 만들 수 있습니다"

msgctxt "DT_LoadingScreenTips@e0@939"
msgid "You can align multiple <Bold>solar generators</> by using <Bold>Shift + LMB</>"
msgstr "<Bold>Shift + 좌클릭</>으로 여러 <Bold>태양광 발전기</>를 정렬할 수 있습니다"

# ---------------------------------------------------------- DT_Materials
msgctxt "DT_Materials@e0@f0"
msgid "Titanium"
msgstr "티타늄"

msgctxt "DT_Materials@e0@12c"
msgid "Light and strong general-purpose building material used in station and starship construction"
msgstr "스테이션과 우주선 건조에 쓰이는 가볍고 튼튼한 범용 건축재"

msgctxt "DT_Materials@e0@284"
msgid "Composite"
msgstr "복합재"

msgctxt "DT_Materials@e0@2c1"
msgid "Flexible carbon nano-material which can be used as a basis for many other materials"
msgstr "다양한 재료의 기반이 되는 유연한 탄소 나노 소재"

msgctxt "DT_Materials@e0@410"
msgid "Gold"
msgstr "금"

msgctxt "DT_Materials@e0@448"
msgid "Rare metal used in all forms of electronics and circuitry"
msgstr "모든 종류의 전자 회로에 쓰이는 희귀 금속"

msgctxt "DT_Materials@e0@57d"
msgid "Titanium Ore"
msgstr "티타늄 광석"

msgctxt "DT_Materials@e0@5bd"
msgid "Raw ore that can be smelted into titanium metal used in construction"
msgstr "제련하여 건설용 티타늄 금속으로 만들 수 있는 원광석"

msgctxt "DT_Materials@e0@6fb"
msgid "Gold Ore"
msgstr "금 광석"

msgctxt "DT_Materials@e0@737"
msgid "Raw ore that can be smelted into usable metal"
msgstr "제련하여 사용 가능한 금속으로 만들 수 있는 원광석"

msgctxt "DT_Materials@e0@85e"
msgid "Silica"
msgstr "규소"

msgctxt "DT_Materials@e0@898"
msgid "Raw material used to produce glass-fibre and other materials"
msgstr "유리섬유 및 기타 재료 생산에 쓰이는 원자재"

msgctxt "DT_Materials@e0@9ce"
msgid "Computers"
msgstr "컴퓨터"

msgctxt "DT_Materials@e0@a0b"
msgid "Quantum-based computing matrix used for advanced station modules and starships"
