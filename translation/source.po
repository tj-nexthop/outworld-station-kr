#: DT_Tutorials export[0] offset=0x1ebf
#. encoding=ASCII len_field=457
msgctxt "DT_Tutorials@e0@1ebf"
msgid "You have now unlocked a new <Bold>Location</> where you can found a <Bold>new station</>.\r\n\r\nNew locations can provide access to <Bold>new or rare resource types</>, and can be accessed by clicking the <Bold>New Station</> button in the <Bold>station toolbar</>, or from the <Bold>System View</>.\r\n\r\n<Bold>Be warned:</> These locations can also harbour more <Bold>deadly threats and events</> which will require you to protect your stations more carefully."
msgstr ""

