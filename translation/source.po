#: DT_ContractText export[0] offset=0xf1b
#. encoding=ASCII len_field=233
msgctxt "DT_ContractText@e0@f1b"
msgid "You've done some truly amazing work in this sector, Commander.\r\n\r\n<Bold>Station Command</> has taken notice, and have decided to <Bold>promote</> you to the rank of <Bold>Captain</>!\r\n\r\nYou should feel extremely proud of yourself..."
msgstr ""

#: DT_ContractText export[0] offset=0x1049
#. encoding=ASCII len_field=211
msgctxt "DT_ContractText@e0@1049"
msgid "You've completed the <Bold>initial phase of development</> in this system.\r\n\r\nPlease continue to expand your station and we'll be in touch very soon with <Bold>new technologies</> and <Bold>further orders</>..."
msgstr ""

#: DT_ContractText export[0] offset=0x1161
#. encoding=ASCII len_field=44
