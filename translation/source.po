msgstr ""

#: DT_Tutorials export[0] offset=0x2c47
#. encoding=ASCII len_field=301
msgctxt "DT_Tutorials@e0@2c47"
msgid "Larger ships can have one or more <Bold>micro fusion reactor</> components.\r\n\r\nOnce completed, these will begin to go <Bold>critical</>, and will <Bold>explode</> if allowed to fully melt down.\r\n\r\nTo avoid this the ship must be <Bold>fully fuelled</> in a <Bold>Fuel Bay</> before the timer runs out."
msgstr ""

