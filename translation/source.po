msgctxt "DT_Levels@e0@d7e2"
msgid "Mission Complete, Station Commander: <Bold>Target Destroyed.</>\r\n\r\nBecause of your success in this mission, we've decided to promote you to the rank of <Bold>Station Captain!</>"
