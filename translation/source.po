#: DT_Tutorials export[0] offset=0x32c
#. encoding=ASCII len_field=377
msgctxt "DT_Tutorials@e0@32c"
msgid "When starting out, the main way to <Bold>gather resources</> is to feed <Bold>asteroids</> and other objects into an <Bold>Atomizer module.</>\r\n\r\nUse <Bold>left-drag</> to drag a single object to your <Bold>Atomizer</> and drop into the opening.\r\n\r\nYou can also <Bold>Shift-Left-Click</> to drag <Bold>multiple objects</> up to the <Bold>maximum carry weight</> of your drone."
msgstr ""

