msgctxt "DT_Tutorials@e0@4855"
msgid "You can use the <Bold>Multi-Select</> tool to select multiple station modules and perform operations on all of them at the same time.\r\n\r\nTo use the tool, click the Multi-Select button from the lower toolbar and <Bold>Left-Click</> or <Bold>Left-Drag</> station modules to select them.\r\n\r\nClick again or hold <Bold>Shift</> while dragging to <Bold>deselect</> modules.\r\n\r\nThe Multi-Select toolbar will appear and you can click one of the functions to apply it to all selected modules."
msgstr ""

#: DT_Tutorials export[0] offset=0x4a8b
