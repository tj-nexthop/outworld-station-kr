msgctxt "DT_Tutorials@e0@5c1b"
msgid "Use the <Bold>Recycler</> to turn your unwanted items, materials and parts into <Bold>Tokens</>.\r\n\r\nTokens can then be spent on various <Bold>rewards</> such as Overdrive Cores, Tech Points and even to directly purchase completed ships.\r\n\r\nThe higher-value the resource you send into the Recycler, the more progress you will make towards the next Token.\r\n\r\nPlease note: each time you purchase a Token, the next Token will cost more resources to purchase."
msgstr ""

#: DT_Tutorials export[0] offset=0x5df6
#. encoding=ASCII len_field=12
msgctxt "DT_Tutorials@e0@5df6"
msgid "07_RECYCLER"
msgstr ""

#: DT_Tutorials export[0] offset=0x5e40
#. encoding=ASCII len_field=11
msgctxt "DT_Tutorials@e0@5e40"
msgid "Laboratory"
msgstr ""

#: DT_Tutorials export[0] offset=0x5e7e
#. encoding=ASCII len_field=351
msgctxt "DT_Tutorials@e0@5e7e"
msgid "The <Bold>Laboratory</> can be used to unlock <Bold>alternative and more efficient recipes</> for commonly used items, materials and parts.\r\n\r\nTo unlock an alternate recipe, feed in the <Bold>required resources</> as shown in the popup list and then select it.\r\n\r\nThe alternative recipe will then appear in the recipe list of the appropriate factory."
msgstr ""

#: DT_Tutorials export[0] offset=0x5ff1
#. encoding=ASCII len_field=14
msgctxt "DT_Tutorials@e0@5ff1"
msgid "07_LABORATORY"
msgstr ""

#: DT_Tutorials export[0] offset=0x603d
#. encoding=ASCII len_field=16
msgctxt "DT_Tutorials@e0@603d"
msgid "Overdrive Cores"
msgstr ""

#: DT_Tutorials export[0] offset=0x6080
#. encoding=ASCII len_field=346
msgctxt "DT_Tutorials@e0@6080"
msgid "Overdrive Cores can be inserted into compatible modules to substantially increase their efficiency and output.\r\n\r\nMost factories and resource extractors can be overdriven by dragging an Overdrive Core into the slot located next to its Max Efficiency slider.\r\n\r\nOverdrive Cores can be purchased with Tokens in the Recycler, or found in the world."
msgstr ""

