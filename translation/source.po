#: DT_Tutorials export[0] offset=0x23e7
#. encoding=ASCII len_field=413
msgctxt "DT_Tutorials@e0@23e7"
msgid "Most recipes can be <Bold>synthesized</> directly from your Inventory (Hotkey = <Bold>TAB</>).\r\n\r\nThis is done by opening the <Bold>drone inventory</> and clicking the <Bold>synthesizer</> tab.\r\n\r\nSelect the recipe from the list, and if you have the required materials you can click the button to start the process.\r\n\r\nYou can automatically repeat the process by toggling the <Bold>repeat</> button to the right."
msgstr ""

