msgid "Blueprints"
msgstr ""

#: DT_Tutorials export[0] offset=0x4ac3
#. encoding=ASCII len_field=478
msgctxt "DT_Tutorials@e0@4ac3"
msgid "You can use <Bold>Blueprints</> to quickly and easily duplicate multiple station modules.\r\n\r\nTo create a blueprint, use the <Bold>Multi-Select</> tool to select multiple modules and click the <Bold>Create Blueprint</> button to open the blueprint creation menu.\r\n\r\nWhen you are satisfied, click the <Bold>Create</> button to form a new blueprint from the selected modules.\r\n\r\nYou can then access your previously created blueprints from the <Bold>Build > Blueprints</> category."
msgstr ""

