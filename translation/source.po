msgctxt "DT_Tutorials@e0@5c15"
msgid "Use the <Bold>Recycler</> to turn your unwanted items, materials and parts into <Bold>Tokens</>.\r\n\r\nTokens can then be spent on various <Bold>rewards</> such as <Bold>Overdrive Cores</> and <Bold>Tech Points</>.\r\n\r\nThe higher-value the resource you send into the Recycler, the more progress you will make towards the next Token.\r\n\r\nPlease note: each time you purchase a Token, the next Token will cost more resources to purchase."
msgstr ""

#: DT_Tutorials export[0] offset=0x5dd7
#. encoding=ASCII len_field=12
msgctxt "DT_Tutorials@e0@5dd7"
msgid "07_RECYCLER"
msgstr ""

#: DT_Tutorials export[0] offset=0x5e21
#. encoding=ASCII len_field=11
msgctxt "DT_Tutorials@e0@5e21"
msgid "Laboratory"
msgstr ""

#: DT_Tutorials export[0] offset=0x5e5f
#. encoding=ASCII len_field=351
msgctxt "DT_Tutorials@e0@5e5f"
msgid "The <Bold>Laboratory</> can be used to unlock <Bold>alternative and more efficient recipes</> for commonly used items, materials and parts.\r\n\r\nTo unlock an alternate recipe, feed in the <Bold>required resources</> as shown in the popup list and then select it.\r\n\r\nThe alternative recipe will then appear in the recipe list of the appropriate factory."
msgstr ""

#: DT_Tutorials export[0] offset=0x5fd2
#. encoding=ASCII len_field=14
msgctxt "DT_Tutorials@e0@5fd2"
msgid "07_LABORATORY"
msgstr ""

