#: DT_ContractText export[0] offset=0x1356
#. encoding=ASCII len_field=104
msgctxt "DT_ContractText@e0@1356"
msgid "<Bold>Drone Control Initiated...</>\r\n\r\nWelcome to <Bold>Stargate Control Alpha</>, Station Commander..."
msgstr ""

#: DT_ContractText export[0] offset=0x13f1
#. encoding=ASCII len_field=100
msgctxt "DT_ContractText@e0@13f1"
msgid "<Enemy>The Void</> is now only light-minutes away from Terra Prime and we're running out of time..."
msgstr ""

#: DT_ContractText export[0] offset=0x1488
#. encoding=ASCII len_field=173
msgctxt "DT_ContractText@e0@1488"
msgid "We need to get that <Bold>Jumpgate Buffer</> back online now, so we can re-initiate <Bold>The Gate</> and escape to the <Bold>TAU system</> before this system is destroyed."
msgstr ""

#: DT_ContractText export[0] offset=0x1586
#. encoding=ASCII len_field=135
msgctxt "DT_ContractText@e0@1586"
msgid "We just need to run a few <Bold>tests</> on your Drone's <Bold>control routines</>...\r\n\r\nFollow the steps and then we can get to work."
msgstr ""

#: DT_ContractText export[0] offset=0x1640
#. encoding=ASCII len_field=186
msgctxt "DT_ContractText@e0@1640"
msgid "OK, now we need to clear the <Enemy>wreckage</> from around the damaged jumpgate buffer before we can replace it.\r\n\r\nWe recommend using your <Bold>Neutron Lazer</> to accomplish this..."
msgstr ""

#: DT_ContractText export[0] offset=0x172d
#. encoding=ASCII len_field=168
msgctxt "DT_ContractText@e0@172d"
msgid "We can now <Bold>deconstruct</> the damaged buffer to clear space for the new buffer we'll need to produce...\r\n\r\nYou can use the <Bold>Sell mode</> to accomplish this."
msgstr ""

#: DT_ContractText export[0] offset=0x1808
#. encoding=ASCII len_field=139
msgctxt "DT_ContractText@e0@1808"
msgid "We need to get a new buffer up and running as soon as we can, but all our factories were <Bold>dismantled</> to build <Bold>The Gate</>..."
msgstr ""

#: DT_ContractText export[0] offset=0x18c6
#. encoding=ASCII len_field=163
msgctxt "DT_ContractText@e0@18c6"
msgid "We'll need to get a small factory up and running to manufacture the <Bold>Stargate Parts</> we need...\r\n\r\nStart by collecting the items left in your <Bold>HUB</>."
msgstr ""

#: DT_ContractText export[0] offset=0x199c
#. encoding=ASCII len_field=83
msgctxt "DT_ContractText@e0@199c"
msgid "We'll need some basic materials before we can start building more complex parts..."
msgstr ""

#: DT_ContractText export[0] offset=0x1a22
#. encoding=ASCII len_field=144
msgctxt "DT_ContractText@e0@1a22"
msgid "Construct an <Bold>Atomizer</> to let us turn collected asteroids into raw materials, and a <Bold>Smelter</> to turn these into useable metals."
msgstr ""

#: DT_ContractText export[0] offset=0x1ae5
#. encoding=ASCII len_field=145
msgctxt "DT_ContractText@e0@1ae5"
msgid "Now our <Bold>Atomizer</> is up and running we can collect asteroids floating around our station and drop them into the opening to process them."
msgstr ""

#: DT_ContractText export[0] offset=0x1ba9
#. encoding=ASCII len_field=160
msgctxt "DT_ContractText@e0@1ba9"
msgid "All factories need to have a <Bold>recipe</> selected in order to function.\r\n\r\nChoose the <Bold>Titanium</> recipe now from your <Bold>Smelter's popup menu</>."
msgstr ""

#: DT_ContractText export[0] offset=0x1c7c
#. encoding=ASCII len_field=319
msgctxt "DT_ContractText@e0@1c7c"
msgid "Automate the movement of items and materials around your station by <Bold>linking</> modules together - they will intelligently <Bold>send required items</> to modules they are linked to.\r\n\r\nLink your <Bold>Atomizer</> to your <Bold>Smelter</> and your <Bold>Smelter</> to your <Bold>HUB</> to start sending items now."
msgstr ""

#: DT_ContractText export[0] offset=0x1dee
#. encoding=ASCII len_field=192
msgctxt "DT_ContractText@e0@1dee"
msgid "If you have made a mistake linking modules together you can <Bold>unlink</> them by repeating the same link action.\r\n\r\nWe recommend unlinking your <Bold>Smelter</> from your <Bold>HUB</> now."
msgstr ""

#: DT_ContractText export[0] offset=0x1ee1
#. encoding=ASCII len_field=138
msgctxt "DT_ContractText@e0@1ee1"
msgid "We're going to need some <Bold>additional modules</> to create our mini factory.\r\n\r\nPlease build the required modules so we can continue."
msgstr ""

#: DT_ContractText export[0] offset=0x1f9e
#. encoding=ASCII len_field=95
msgctxt "DT_ContractText@e0@1f9e"
msgid "Now <Bold>link</> all of your new modules together as directed to form <Bold>supply chains</>."
msgstr ""

#: DT_ContractText export[0] offset=0x2030
#. encoding=ASCII len_field=163
msgctxt "DT_ContractText@e0@2030"
msgid "Our <Bold>power generation</> is getting dangerously low...\r\n\r\nBuild a <Bold>Solar Panel</> and <Bold>align</> it to the sun's direction to increase power levels."
msgstr ""

#: DT_ContractText export[0] offset=0x2106
#. encoding=ASCII len_field=160
msgctxt "DT_ContractText@e0@2106"
msgid "Before we continue, please check that these <Bold>advanced functions</> are working correctly as they will come in very useful as your station expands further."
msgstr ""

#: DT_ContractText export[0] offset=0x21d9
#. encoding=ASCII len_field=145
msgctxt "DT_ContractText@e0@21d9"
msgid "All modules have <Bold>advanced settings</> which give you more control over what they will process and store - please test these functions now."
msgstr ""

#: DT_ContractText export[0] offset=0x229d
#. encoding=ASCII len_field=195
msgctxt "DT_ContractText@e0@229d"
msgid "Completing <Bold>Objectives</> allows us to unlock <Bold>new technologies, items, modules and ships</>.\r\n\r\nSelect the <Bold>Complete The Gate</> objective now from the <Bold>Objectives Panel</>."
msgstr ""

#: DT_ContractText export[0] offset=0x2393
#. encoding=ASCII len_field=321
msgctxt "DT_ContractText@e0@2393"
msgid "To rebuild the damaged buffer unit we'll need to construct complex <Bold>Stargate Parts</>, using the materials our smelters have processed.\r\n\r\nWe can use our Drone's <Bold>Synthesizer</> function to produce these parts. This is accessed from the <Bold>Synthesizer Tab</> on your Drone's <Bold>inventory</> popup menu..."
msgstr ""

#: DT_ContractText export[0] offset=0x2507
#. encoding=ASCII len_field=145
msgctxt "DT_ContractText@e0@2507"
msgid "Now we've fabricated the required <Bold>Stargate Parts</>, we should place these in our <Bold>HUB</> in order to complete the current Objective."
msgstr ""

#: DT_ContractText export[0] offset=0x25cb
#. encoding=ASCII len_field=183
msgctxt "DT_ContractText@e0@25cb"
msgid "If you <Bold>run out of materials</> while synthesizing, don't forget to feed more asteroids into your <Bold>Atomizer</>, and collect more completed materials from your <Bold>HUB</>."
msgstr ""

#: DT_ContractText export[0] offset=0x2717
#. encoding=ASCII len_field=134
msgctxt "DT_ContractText@e0@2717"
msgid "Local <Bold>star constellations</> fixed and locked...\r\n\r\nConfirmed... We've arrived in the <Bold>TAU system</>, Station Commander..."
msgstr ""

#: DT_ContractText export[0] offset=0x27d0
#. encoding=ASCII len_field=185
msgctxt "DT_ContractText@e0@27d0"
msgid "<Bold>Long-range scans</> reveal that this <Bold>mysterious</> system contains all the raw resources we'll need to develop our <Bold>Intergalactic Arkship</> and escape this galaxy...."
msgstr ""

#: DT_ContractText export[0] offset=0x28bc
#. encoding=ASCII len_field=213
msgctxt "DT_ContractText@e0@28bc"
msgid "However, it appears that <Bold>The Void's</> expansion is <Bold>accelerating</>, and we may not have as long here as we hoped before it reaches us again...\r\n\r\n<Bold>So we better get to work, Station Commander!</>"
msgstr ""

#: DT_ContractText export[0] offset=0x29c4
#. encoding=ASCII len_field=74
msgctxt "DT_ContractText@e0@29c4"
msgid "Select an <Bold>Objective</> from the <Bold>Objectives Panel</> to start."
msgstr ""

